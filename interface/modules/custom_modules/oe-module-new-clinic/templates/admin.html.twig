{% extends 'base.html.twig' %}

{% block page_subtitle %}
<div class="oe-nc-page-heading__subtitle">{{ 'Queue, roles, and completion thresholds'|xlt }}</div>
{% endblock %}

{% block page_heading_actions %}
<button type="button" class="btn btn-primary btn-sm" id="nc-admin-save" disabled>
    {{ 'Save changes'|xlt }}
</button>
<span class="text-muted small" id="nc-admin-status"></span>
{% endblock %}

{% block content %}
{% if enable_react_admin_hub|default(true) %}
<div
    data-island="admin-hub"
    data-props="{{ {
        ajaxUrl: ajax_url,
        csrfToken: csrf_token,
        webroot: webroot,
        clinicFacilityId: desk_facility_id|default(0)|number_format(0, '', '')
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Admin Hub' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_admin_hub|default(true) %}
<link rel="stylesheet" href="{{ assets_url }}/modern/admin-hub.css?v={{ asset_version }}">
<script type="module" src="{{ assets_url }}/modern/admin-hub.js?v={{ asset_version }}"></script>
{% endif %}
{% endblock %}
