{% extends 'base.html.twig' %}

{% block page_subtitle %}
<div class="nc-page-heading-subtitle">{{ 'Queue, roles, and completion thresholds'|xlt }}</div>
{% endblock %}

{% block page_heading_actions %}
<button type="button" class="nc-btn nc-btn-sm nc-btn-primary" id="nc-admin-save" disabled>
    {{ 'Save changes'|xlt }}
</button>
<span class="nc-text-muted nc-text-sm" id="nc-admin-status"></span>
{% endblock %}

{% block content %}
{% if enable_react_admin_hub|default(true) %}
<div
    data-island="admin-hub"
    data-props="{{ {
        ajaxUrl: ajax_url,
        csrfToken: csrf_token,
        webroot: webroot,
        clinicFacilityId: desk_facility_id|default(0)|number_format(0, '', '')
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Admin Hub' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_admin_hub|default(true) %}
{% include 'partials/island-assets.html.twig' %}
{% endif %}
{% endblock %}
