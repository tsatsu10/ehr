{% extends 'base.html.twig' %}

{% block page_heading_actions %}
<button type="button" class="btn btn-outline-secondary btn-sm" id="nc-registry-refresh">{{ 'Refresh'|xlt }}</button>
<button type="button" class="btn btn-outline-secondary btn-sm" id="nc-registry-save-filter">{{ 'Save filters'|xlt }}</button>
<button type="button" class="btn btn-outline-danger btn-sm d-none" id="nc-registry-delete-filter">{{ 'Delete saved'|xlt }}</button>
<button type="button" class="btn btn-outline-primary btn-sm" id="nc-registry-export">{{ 'Export CSV'|xlt }}</button>
{% endblock %}

{% block content %}
<link rel="stylesheet" href="{{ assets_url }}/css/patient-registry.css?v={{ asset_version }}">

<div id="nc-patient-registry"
     class="oe-nc-registry"
     data-ajax-url="{{ ajax_url }}"
     data-csrf-token="{{ csrf_token }}"
     data-chart-url-base="{{ chart_url_base|attr }}"
     data-billing-threshold="{{ billing_threshold }}">
    <div class="row">
        <aside class="col-lg-4 mb-3">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>{{ 'Filters'|xlt }}</strong>
                    <select class="form-control form-control-sm w-auto" id="nc-registry-preset" aria-label="{{ 'Presets'|xlt }}">
                        <option value="">{{ 'Presets…'|xlt }}</option>
                    </select>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label for="nc-registry-record-status">{{ 'Record status'|xlt }}</label>
                        <select class="form-control form-control-sm" id="nc-registry-record-status">
                            <option value="active_only">{{ 'Active patients only'|xlt }}</option>
                            <option value="include_inactive">{{ 'Include inactive'|xlt }}</option>
                            <option value="deceased_only">{{ 'Deceased only'|xlt }}</option>
                            <option value="all">{{ 'All'|xlt }}</option>
                        </select>
                    </div>
                    <div class="form-row">
                        <div class="form-group col-6">
                            <label for="nc-registry-age-min">{{ 'Age from'|xlt }}</label>
                            <input type="number" class="form-control form-control-sm" id="nc-registry-age-min" min="0">
                        </div>
                        <div class="form-group col-6">
                            <label for="nc-registry-age-max">{{ 'Age to'|xlt }}</label>
                            <input type="number" class="form-control form-control-sm" id="nc-registry-age-max" min="0">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="nc-registry-sex">{{ 'Sex'|xlt }}</label>
                        <select class="form-control form-control-sm" id="nc-registry-sex">
                            <option value="any">{{ 'Any'|xlt }}</option>
                            <option value="Female">{{ 'Female'|xlt }}</option>
                            <option value="Male">{{ 'Male'|xlt }}</option>
                            <option value="Other">{{ 'Other'|xlt }}</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="nc-registry-name">{{ 'Name contains'|xlt }}</label>
                        <input type="search" class="form-control form-control-sm" id="nc-registry-name">
                    </div>
                    <div class="form-group">
                        <label for="nc-registry-mrn">{{ 'MRN'|xlt }}</label>
                        <input type="search" class="form-control form-control-sm" id="nc-registry-mrn">
                    </div>
                    <div class="form-row">
                        <div class="form-group col-6">
                            <label for="nc-registry-national-id">{{ 'National ID'|xlt }}</label>
                            <input type="search" class="form-control form-control-sm" id="nc-registry-national-id">
                        </div>
                        <div class="form-group col-6">
                            <label for="nc-registry-nhis">{{ 'NHIS number'|xlt }}</label>
                            <input type="search" class="form-control form-control-sm" id="nc-registry-nhis">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="nc-registry-phone">{{ 'Phone'|xlt }}</label>
                        <input type="search" class="form-control form-control-sm" id="nc-registry-phone">
                    </div>
                    <div class="form-row">
                        <div class="form-group col-6">
                            <label for="nc-registry-completion-min">{{ 'Completion % min'|xlt }}</label>
                            <input type="number" class="form-control form-control-sm" id="nc-registry-completion-min" min="0" max="100">
                        </div>
                        <div class="form-group col-6">
                            <label for="nc-registry-completion-max">{{ 'Completion % max'|xlt }}</label>
                            <input type="number" class="form-control form-control-sm" id="nc-registry-completion-max" min="0" max="100">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="nc-registry-active-visit">{{ 'Active visit today'|xlt }}</label>
                        <select class="form-control form-control-sm" id="nc-registry-active-visit">
                            <option value="">{{ 'Any'|xlt }}</option>
                            <option value="yes">{{ 'Yes'|xlt }}</option>
                            <option value="no">{{ 'No'|xlt }}</option>
                        </select>
                    </div>
                    <details class="oe-nc-registry-visit-filters mb-2">
                        <summary class="small font-weight-bold">{{ 'Visit filters'|xlt }}</summary>
                        <div class="mt-2">
                            <div class="form-group">
                                <label for="nc-registry-visit-states">{{ 'Visit state'|xlt }}</label>
                                <select class="form-control form-control-sm" id="nc-registry-visit-states" multiple size="5"
                                        aria-label="{{ 'Visit state'|xlt }}"></select>
                                <small class="text-muted">{{ 'Ctrl+click to select multiple'|xlt }}</small>
                            </div>
                            <div class="form-group">
                                <label for="nc-registry-visit-type">{{ 'Visit type'|xlt }}</label>
                                <select class="form-control form-control-sm" id="nc-registry-visit-type">
                                    <option value="">{{ 'Any'|xlt }}</option>
                                </select>
                            </div>
                            <div class="form-row">
                                <div class="form-group col-6">
                                    <label for="nc-registry-visit-from">{{ 'Visit from'|xlt }}</label>
                                    <input type="date" class="form-control form-control-sm" id="nc-registry-visit-from">
                                </div>
                                <div class="form-group col-6">
                                    <label for="nc-registry-visit-to">{{ 'Visit to'|xlt }}</label>
                                    <input type="date" class="form-control form-control-sm" id="nc-registry-visit-to">
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="nc-registry-payment">{{ 'Payment status'|xlt }}</label>
                                <select class="form-control form-control-sm" id="nc-registry-payment">
                                    <option value="any">{{ 'Any'|xlt }}</option>
                                    <option value="paid">{{ 'Paid'|xlt }}</option>
                                    <option value="outstanding">{{ 'Outstanding'|xlt }}</option>
                                </select>
                            </div>
                            <div class="form-row">
                                <div class="form-group col-6">
                                    <label for="nc-registry-last-visit-from">{{ 'Last visit from'|xlt }}</label>
                                    <input type="date" class="form-control form-control-sm" id="nc-registry-last-visit-from">
                                </div>
                                <div class="form-group col-6">
                                    <label for="nc-registry-last-visit-to">{{ 'Last visit to'|xlt }}</label>
                                    <input type="date" class="form-control form-control-sm" id="nc-registry-last-visit-to">
                                </div>
                            </div>
                        </div>
                    </details>
                    <details class="oe-nc-registry-clinical-filters mb-2">
                        <summary class="small font-weight-bold">{{ 'Clinical filters'|xlt }}</summary>
                        <div class="mt-2">
                            <div class="form-group">
                                <label for="nc-registry-condition-key">{{ 'Condition'|xlt }}</label>
                                <select class="form-control form-control-sm" id="nc-registry-condition-key">
                                    <option value="">{{ 'Any / manual below'|xlt }}</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="nc-registry-problem-title">{{ 'Problem title contains'|xlt }}</label>
                                <input type="search" class="form-control form-control-sm" id="nc-registry-problem-title"
                                       placeholder="{{ 'e.g. malaria'|xlt }}">
                            </div>
                            <div class="form-group">
                                <label for="nc-registry-icd-prefix">{{ 'ICD prefix'|xlt }}</label>
                                <input type="search" class="form-control form-control-sm" id="nc-registry-icd-prefix"
                                       placeholder="{{ 'e.g. B50'|xlt }}">
                            </div>
                            <div class="form-group">
                                <label for="nc-registry-lab-test">{{ 'Lab test contains'|xlt }}</label>
                                <input type="search" class="form-control form-control-sm" id="nc-registry-lab-test"
                                       placeholder="{{ 'e.g. malaria RDT'|xlt }}">
                            </div>
                            <div class="form-group">
                                <label for="nc-registry-confirmation-source">{{ 'Confirmation source'|xlt }}</label>
                                <select class="form-control form-control-sm" id="nc-registry-confirmation-source">
                                    <option value="problem_active">{{ 'Problem list — active'|xlt }}</option>
                                </select>
                            </div>
                            <div class="form-row">
                                <div class="form-group col-6">
                                    <label for="nc-registry-age-dx-min">{{ 'Age at diagnosis from'|xlt }}</label>
                                    <input type="number" class="form-control form-control-sm" id="nc-registry-age-dx-min" min="0" max="120">
                                </div>
                                <div class="form-group col-6">
                                    <label for="nc-registry-age-dx-max">{{ 'Age at diagnosis to'|xlt }}</label>
                                    <input type="number" class="form-control form-control-sm" id="nc-registry-age-dx-max" min="0" max="120">
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group col-6">
                                    <label for="nc-registry-diagnosis-from">{{ 'Diagnosis from'|xlt }}</label>
                                    <input type="date" class="form-control form-control-sm" id="nc-registry-diagnosis-from">
                                </div>
                                <div class="form-group col-6">
                                    <label for="nc-registry-diagnosis-to">{{ 'Diagnosis to'|xlt }}</label>
                                    <input type="date" class="form-control form-control-sm" id="nc-registry-diagnosis-to">
                                </div>
                            </div>
                        </div>
                    </details>
                    <details class="oe-nc-registry-scheduling-filters mb-2">
                        <summary class="small font-weight-bold">{{ 'Scheduling & recalls'|xlt }}</summary>
                        <div class="mt-2">
                            <div class="form-group">
                                <label for="nc-registry-appointment-today">{{ 'Appointment today'|xlt }}</label>
                                <select class="form-control form-control-sm" id="nc-registry-appointment-today">
                                    <option value="">{{ 'Any'|xlt }}</option>
                                    <option value="yes">{{ 'Yes'|xlt }}</option>
                                    <option value="no">{{ 'No'|xlt }}</option>
                                </select>
                            </div>
                            <div class="form-row">
                                <div class="form-group col-6">
                                    <label for="nc-registry-appointment-from">{{ 'Appointment from'|xlt }}</label>
                                    <input type="date" class="form-control form-control-sm" id="nc-registry-appointment-from">
                                </div>
                                <div class="form-group col-6">
                                    <label for="nc-registry-appointment-to">{{ 'Appointment to'|xlt }}</label>
                                    <input type="date" class="form-control form-control-sm" id="nc-registry-appointment-to">
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="nc-registry-recall-due">{{ 'Recall due'|xlt }}</label>
                                <select class="form-control form-control-sm" id="nc-registry-recall-due">
                                    <option value="any">{{ 'Any'|xlt }}</option>
                                    <option value="overdue">{{ 'Overdue'|xlt }}</option>
                                    <option value="due_soon">{{ 'Due soon (14 days)'|xlt }}</option>
                                </select>
                            </div>
                            <div class="form-row">
                                <div class="form-group col-6">
                                    <label for="nc-registry-recall-from">{{ 'Recall from'|xlt }}</label>
                                    <input type="date" class="form-control form-control-sm" id="nc-registry-recall-from">
                                </div>
                                <div class="form-group col-6">
                                    <label for="nc-registry-recall-to">{{ 'Recall to'|xlt }}</label>
                                    <input type="date" class="form-control form-control-sm" id="nc-registry-recall-to">
                                </div>
                            </div>
                        </div>
                    </details>
                    <div class="d-flex">
                        <button type="button" class="btn btn-primary btn-sm mr-2" id="nc-registry-apply">{{ 'Apply'|xlt }}</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="nc-registry-clear">{{ 'Clear'|xlt }}</button>
                    </div>
                </div>
            </div>
        </aside>
        <section class="col-lg-8">
            <div class="oe-nc-registry-summary text-muted small mb-2" id="nc-registry-summary">
                {{ 'Apply filters to search the registry.'|xlt }}
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover" id="nc-registry-table">
                    <thead>
                        <tr>
                            <th>{{ 'Name'|xlt }}</th>
                            <th>{{ 'Age'|xlt }}</th>
                            <th>{{ 'Sex'|xlt }}</th>
                            <th>{{ 'MRN'|xlt }}</th>
                            <th class="oe-nc-registry-col-condition">{{ 'Condition'|xlt }}</th>
                            <th>{{ 'Completion'|xlt }}</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="nc-registry-rows">
                        <tr><td colspan="7" class="text-muted"><em>{{ 'No search yet.'|xlt }}</em></td></tr>
                    </tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center" id="nc-registry-pagination"></div>
        </section>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="{{ assets_url }}/js/patient-registry.js?v={{ asset_version }}"></script>
<script>
(function () {
    function bootRegistry() {
        if (window.NewClinicPatientRegistry) {
            window.NewClinicPatientRegistry.init(document.getElementById('nc-patient-registry'));
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootRegistry);
    } else {
        bootRegistry();
    }
})();
</script>
{% endblock %}
