{% extends 'base.html.twig' %}

{% block page_heading %}{% endblock %}

{% block page_heading_actions %}
<div class="nc-flex nc-flex-wrap nc-items-center nc-gap-2">
    <a class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary" href="javascript:window.close()">
        {{ 'Close'|xlt }}
    </a>
</div>
{% endblock %}

{% block content %}
<div
    id="nc-rx-history"
    data-island="rx-history"
    data-props="{{ {
        ajaxUrl: ajax_url,
        csrfToken: csrf_token,
        moduleUrl: module_url,
        pid: pid
    }|json_encode|e('html_attr') }}"
></div>
{% endblock %}

{% block scripts %}
{% include 'partials/island-assets.html.twig' %}
{% endblock %}
