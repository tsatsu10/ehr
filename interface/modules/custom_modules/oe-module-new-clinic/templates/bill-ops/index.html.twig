{% extends 'base.html.twig' %}

{% block page_heading_actions %}
<div class="nc-flex nc-flex-wrap nc-items-center nc-billops-toolbar" id="nc-billops-toolbar">
    <div class="nc-btn-group nc-btn-group-sm nc-mr-2 nc-mb-1" role="group" aria-label="{{ 'Billing tabs'|xlt }}">
        {% if can_correct %}
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'corrections' %} active{% endif %}" data-tab="corrections">
            {{ 'Corrections'|xlt }}
        </button>
        {% endif %}
        {% if can_payment %}
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'payments' %} active{% endif %}" data-tab="payments">
            {{ 'Payments'|xlt }}
        </button>
        {% endif %}
        {% if can_close %}
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'close' %} active{% endif %}" data-tab="close">
            {{ 'Close day'|xlt }}
        </button>
        {% endif %}
        {% if can_outstanding %}
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'outstanding' %} active{% endif %}" data-tab="outstanding">
            {{ 'Outstanding'|xlt }}
        </button>
        {% endif %}
        {% if can_insurance %}
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'insurance' %} active{% endif %}" data-tab="insurance">
            {{ 'Insurance'|xlt }}
        </button>
        {% endif %}
    </div>
    <a class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-mb-1 nc-mr-1" href="{{ cashier_url|attr }}">{{ 'Cashier'|xlt }}</a>
    <a class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-mb-1 nc-mr-1" href="{{ reports_url|attr }}">{{ 'Reports'|xlt }}</a>
    <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-mb-1" id="nc-billops-refresh" aria-label="{{ 'Refresh'|xlt }}">
        <i class="fa fa-refresh" aria-hidden="true"></i>
    </button>
    <span class="nc-text-muted nc-text-sm nc-mb-1" id="nc-billops-updated"></span>
</div>
{% endblock %}

{% block content %}
{% if enable_react_bill_ops|default(true) %}
<div
    data-island="bill-ops"
    data-props="{{ {
        ajaxUrl: ajax_url,
        csrfToken: csrf_token,
        moduleUrl: module_url,
        cashierUrl: cashier_url,
        reportsUrl: reports_url,
        visitBoardUrl: visit_board_url,
        facilityId: desk_facility_id|default(0)|number_format(0, '', ''),
        initialTab: initial_tab,
        canCorrect: can_correct ? true : false,
        canPayment: can_payment ? true : false,
        canClose: can_close ? true : false,
        canOutstanding: can_outstanding ? true : false,
        canInsurance: can_insurance ? true : false,
        canEdiHistory: can_edi_history ? true : false,
        reopenOnCorrection: reopen_on_correction ? true : false,
        webroot: webroot,
        currencyFormat: currency_format|default({})
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Billing Back Office' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_bill_ops|default(true) %}
{% include 'partials/island-assets.html.twig' %}
{% endif %}
{% endblock %}
