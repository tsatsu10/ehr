{% extends 'base.html.twig' %}

{% block page_subtitle %}
<div class="nc-page-heading-subtitle" id="nc-doctor-date"></div>
{% endblock %}

{% block page_heading_actions %}
<button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary" id="nc-doctor-find-patient">
    {{ '+ Find patient'|xlt }}
</button>
<button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary" id="nc-doctor-refresh" aria-label="{{ 'Refresh'|xlt }}">
    <i class="fa fa-refresh" aria-hidden="true"></i>
</button>
<span class="nc-text-muted nc-text-sm" id="nc-doctor-updated"></span>
{% endblock %}

{% block content %}
{% if enable_react_doctor_desk|default(true) %}
<div
    data-island="doctor-desk"
    data-props="{{ {
        ajaxUrl:               ajax_url,
        csrfToken:             csrf_token,
        facilityId:            desk_facility_id|default(0)|number_format(0, '', ''),
        visitBoardUrl:         visit_board_url,
        multiDoctorFilters:    enable_multi_doctor_filters ? true : false,
        doctorRosterEnabled:   enable_doctor_roster ? true : false,
        advisoryRoutingEnabled: enable_advisory_routing ? true : false,
        sharedDeviceWarning:   enable_shared_device_session_warning ? true : false,
        labPanelOrderEnabled:  lab_panel_order_enabled ? true : false,
        formularyRxEnabled:    formulary_rx_enabled ? true : false,
        labResultsToastEnabled: lab_results_toast_enabled ? true : false,
        canRxAllergyOverride:     can_rx_allergy_override ? true : false,
        currencyFormat:        currency_format|default({}),
        pollMs:                queue_poll_ms|default(30000),
        patientEducationResources: patient_education_resources|default([])
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Doctor Desk' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_doctor_desk|default(true) %}
{% include 'partials/island-assets.html.twig' %}
{% endif %}
{% endblock %}
