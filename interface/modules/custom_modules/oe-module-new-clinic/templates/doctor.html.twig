{% extends 'base.html.twig' %}

{% block page_subtitle %}
<div class="oe-nc-page-heading__subtitle" id="nc-doctor-date"></div>
{% endblock %}

{% block page_heading_actions %}
{% if enable_multi_doctor_filters %}
<select class="form-control form-control-sm" style="max-width:120px;" id="nc-doctor-scope">
    <option value="me">{{ 'Me'|xlt }}</option>
    <option value="all">{{ 'All'|xlt }}</option>
</select>
{% endif %}
<button type="button" class="btn btn-outline-primary btn-sm" id="nc-doctor-refresh">
    {{ 'Refresh'|xlt }}
</button>
<span class="text-muted small" id="nc-doctor-updated"></span>
{% endblock %}

{% block content %}
<div id="nc-doctor-desk"
     data-ajax-url="{{ ajax_url }}"
     data-csrf-token="{{ csrf_token }}"
     data-module-url="{{ module_url }}"
     data-visit-board-url="{{ visit_board_url }}"
     data-webroot="{{ webroot }}"
     data-multi-doctor="{{ enable_multi_doctor_filters ? '1' : '0' }}"
     data-shared-device-warning="{{ enable_shared_device_session_warning ? '1' : '0' }}">
    <div id="nc-doctor-interrupt" class="alert alert-warning d-none mb-3" role="alert">
        <div class="d-flex justify-content-between align-items-start flex-wrap">
            <span id="nc-doctor-interrupt-text"></span>
            <button type="button" class="btn btn-sm btn-outline-secondary ml-2" id="nc-doctor-interrupt-dismiss">
                {{ 'Return to queue'|xlt }}
            </button>
        </div>
    </div>

    <div id="nc-doctor-session-banner" class="alert alert-danger d-none mb-3 nc-shared-device-banner" role="alert">
        <div class="d-flex justify-content-between align-items-start flex-wrap">
            <div id="nc-doctor-session-banner-text">
                <strong>{{ 'Browser session is on another patient.'|xlt }}</strong>
                <div class="small mt-1">{{ 'Restore encounter session or return to the queue before saving.'|xlt }}</div>
            </div>
            <div class="mt-2 mt-md-0 text-nowrap">
                <button type="button" class="btn btn-sm btn-outline-light mr-2" id="nc-doctor-restore-session">
                    {{ 'Restore encounter session'|xlt }}
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" id="nc-doctor-return-queue">
                    {{ 'Return to queue'|xlt }}
                </button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-3">
            <div id="nc-doctor-active-pane">
                <div class="card">
                    <div class="card-body text-muted text-center py-5">
                        <em>{{ 'Pick a patient from the queue to start a consult.'|xlt }}</em>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-3">
            <div class="nc-doctor-queue-panel">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong>{{ 'My queue'|xlt }}</strong>
                    <span class="text-muted small" id="nc-doctor-counts"></span>
                </div>
                <div id="nc-doctor-queue-list"></div>
                <div class="mt-3" id="nc-doctor-reopen-section" style="display:none;">
                    <button type="button" class="btn btn-link btn-sm p-0" id="nc-doctor-reopen-toggle">
                        {{ 'Reopen consult'|xlt }} (<span id="nc-doctor-reopen-count">0</span>)
                    </button>
                    <div id="nc-doctor-reopen-list" class="mt-2" style="display:none;"></div>
                </div>
                <div class="mt-3">
                    <button type="button" class="btn btn-link btn-sm p-0" id="nc-doctor-done-toggle">
                        {{ 'Done today'|xlt }} (<span id="nc-doctor-done-count">0</span>)
                    </button>
                    <div id="nc-doctor-done-list" class="mt-2" style="display:none;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="nc-doctor-reopen-modal" tabindex="-1" role="dialog"
     aria-labelledby="nc-doctor-reopen-title" aria-modal="true" aria-hidden="true" style="display:none;">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="nc-doctor-reopen-title">{{ 'Reopen consult'|xlt }}</h5>
                <button type="button" class="close nc-modal-close" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p id="nc-reopen-patient" class="mb-2"></p>
                <p class="text-muted small">{{ 'Return this visit to your desk for new lab or Rx orders. Signed documentation stays locked.'|xlt }}</p>
                <div class="form-group">
                    <label for="nc-reopen-reason">{{ 'Reason (required, min 10 characters)'|xlt }}</label>
                    <textarea class="form-control" id="nc-reopen-reason" rows="3" minlength="10"></textarea>
                </div>
                <div class="alert alert-danger mt-2 d-none" id="nc-reopen-error"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary nc-modal-close">{{ 'Cancel'|xlt }}</button>
                <button type="button" class="btn btn-warning" id="nc-reopen-confirm">{{ 'Reopen consult'|xlt }}</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="nc-doctor-routing-modal" tabindex="-1" role="dialog"
     aria-labelledby="nc-doctor-routing-title" aria-modal="true" aria-hidden="true" style="display:none;">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="nc-doctor-routing-title">{{ 'Confirm routing'|xlt }}</h5>
                <button type="button" class="close nc-modal-close" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p id="nc-routing-patient" class="mb-2"></p>
                <p class="text-muted small" id="nc-routing-detected"></p>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="nc-routing-lab">
                    <label class="form-check-label" for="nc-routing-lab">{{ 'Send to lab'|xlt }}</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="nc-routing-rx">
                    <label class="form-check-label" for="nc-routing-rx">{{ 'Send to pharmacy'|xlt }}</label>
                </div>
                <div class="form-group mt-2">
                    <label for="nc-routing-notes">{{ 'Notes (optional)'|xlt }}</label>
                    <textarea class="form-control" id="nc-routing-notes" rows="2"></textarea>
                </div>
                <div class="alert alert-danger mt-2 d-none" id="nc-routing-error"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary nc-modal-close">{{ 'Cancel'|xlt }}</button>
                <button type="button" class="btn btn-primary" id="nc-routing-confirm">{{ 'Confirm and route'|xlt }}</button>
            </div>
        </div>
    </div>
</div>
<div class="modal-backdrop fade" id="nc-doctor-modal-backdrop" style="display:none;"></div>
{% endblock %}

{% block scripts %}
<script src="{{ assets_url }}/js/modal-a11y.js?v={{ asset_version }}"></script>
<script src="{{ assets_url }}/js/doctor.js?v={{ asset_version }}"></script>
<script>
(function () {
    function bootDoctor() {
        if (window.NewClinicDoctor) {
            window.NewClinicDoctor.init(document.getElementById('nc-doctor-desk'));
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootDoctor);
    } else {
        bootDoctor();
    }
})();
</script>
{% endblock %}
