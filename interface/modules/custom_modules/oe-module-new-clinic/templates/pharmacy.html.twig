{% extends 'base.html.twig' %}

{% block page_subtitle %}
<div class="oe-nc-page-heading__subtitle" id="nc-pharmacy-date"></div>
{% endblock %}

{% block page_heading_actions %}
<button type="button" class="btn btn-outline-primary btn-sm" id="nc-pharmacy-refresh">
    {{ 'Refresh'|xlt }}
</button>
<span class="text-muted small" id="nc-pharmacy-updated"></span>
{% endblock %}

{% block content %}
{% if enable_react_pharmacy_desk|default(true) %}
<div
    data-island="pharmacy-desk"
    data-props="{{ {
        ajaxUrl:               ajax_url,
        csrfToken:             csrf_token,
        facilityId:            desk_facility_id|default(0)|number_format(0, '', ''),
        visitBoardUrl:         visit_board_url,
        canSkipToPayment:      can_skip_to_payment ? true : false,
        sharedDeviceWarning:   enable_shared_device_session_warning ? true : false,
        canEsignOverride:      can_esign_override ? true : false
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Pharmacy Desk' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_pharmacy_desk|default(true) %}
<link rel="stylesheet" href="{{ assets_url }}/modern/pharmacy-desk.css?v={{ asset_version }}">
<script type="module" src="{{ assets_url }}/modern/pharmacy-desk.js?v={{ asset_version }}"></script>
{% endif %}
{% endblock %}
