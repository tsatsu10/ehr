{% extends 'base.html.twig' %}

{% block page_subtitle %}
<div class="nc-page-heading-subtitle" id="nc-pharmacy-date"></div>
{% endblock %}

{% block page_heading_actions %}
<button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary" id="nc-pharmacy-refresh">
    {{ 'Refresh'|xlt }}
</button>
<span class="nc-text-muted nc-text-sm" id="nc-pharmacy-updated"></span>
{% endblock %}

{% block content %}
{% if enable_react_pharmacy_desk|default(true) %}
<div
    data-island="pharmacy-desk"
    data-props="{{ {
        ajaxUrl:               ajax_url,
        csrfToken:             csrf_token,
        facilityId:            desk_facility_id|default(0)|number_format(0, '', ''),
        visitBoardUrl:         visit_board_url,
        canSkipToPayment:      can_skip_to_payment ? true : false,
        sharedDeviceWarning:   enable_shared_device_session_warning ? true : false,
        canEsignOverride:      can_esign_override ? true : false,
        canSellOtc:            can_sell_otc ? true : false,
        pharmOpsEnabled:       pharm_ops_enabled ? true : false,
        canDispense:           can_dispense ? true : false,
        canUndispensedOverride: can_undispensed_override ? true : false,
        canExternalRxOverride: can_external_rx_override ? true : false,
        pollMs:                  queue_poll_ms|default(30000)
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Pharmacy Desk' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_pharmacy_desk|default(true) %}
{% include 'partials/island-assets.html.twig' %}
{% endif %}
{% endblock %}
