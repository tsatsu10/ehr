{% extends 'base.html.twig' %}

{% block page_heading_actions %}
<div class="d-flex flex-wrap align-items-center oe-nc-comm-toolbar" id="nc-comm-toolbar">
    <div class="btn-group btn-group-sm mr-2 mb-1" role="group" aria-label="{{ 'Lens'|xlt }}">
        <button type="button" class="btn btn-outline-primary active" id="nc-comm-lens-messages" data-lens="messages">
            {{ 'Messages'|xlt }} <span class="badge badge-light" id="nc-comm-count-messages">0</span>
        </button>
        <button type="button" class="btn btn-outline-primary" id="nc-comm-lens-reminders" data-lens="reminders">
            {{ 'Reminders'|xlt }} <span class="badge badge-light" id="nc-comm-count-reminders">0</span>
        </button>
    </div>
    <input type="search"
           class="form-control form-control-sm mr-2 mb-1"
           id="nc-comm-search"
           placeholder="{{ 'Search…'|xlt }}"
           style="width:12rem;max-width:40vw;"
           aria-label="{{ 'Search'|xlt }}">
    <select class="form-control form-control-sm mr-2 mb-1 d-none" id="nc-comm-activity" aria-label="{{ 'Message activity'|xlt }}" style="width:auto;">
        <option value="1">{{ 'Active'|xlt }}</option>
        <option value="0">{{ 'Inactive'|xlt }}</option>
        <option value="all">{{ 'All'|xlt }}</option>
    </select>
    {% if can_view_all_users %}
    <div class="form-check form-check-inline mb-1 mr-2 d-none" id="nc-comm-scope-wrap">
        <input type="checkbox" class="form-check-input" id="nc-comm-show-all">
        <label class="form-check-label small" for="nc-comm-show-all">{{ 'All users'|xlt }}</label>
    </div>
    {% endif %}
    <button type="button" class="btn btn-outline-secondary btn-sm mb-1" id="nc-comm-refresh" aria-label="{{ 'Refresh'|xlt }}">
        <i class="fa fa-refresh" aria-hidden="true"></i>
    </button>
</div>
{% endblock %}

{% block content %}
<link rel="stylesheet" href="{{ assets_url }}/css/communications-hub.css?v={{ asset_version }}">

<div id="nc-communications-hub"
     class="oe-nc-comm-hub"
     data-ajax-url="{{ ajax_url }}"
     data-csrf-token="{{ csrf_token }}"
     data-can-view-all="{{ can_view_all_users ? '1' : '0' }}"
     data-initial-lens="{{ initial_lens|attr }}"
     data-reminder-add-url="{{ reminder_add_url|attr }}"
     data-reminder-log-url="{{ reminder_log_url|attr }}"
     data-legacy-compose-url="{{ legacy_compose_url|attr }}"
     data-webroot="{{ webroot|attr }}">

    <div class="oe-nc-comm-split">
        <section class="oe-nc-comm-list-pane" aria-label="{{ 'List'|xlt }}">
            <div class="oe-nc-comm-list" id="nc-comm-list" role="listbox" aria-label="{{ 'Items'|xlt }}"></div>
            <div class="oe-nc-comm-pagination d-flex justify-content-between align-items-center" id="nc-comm-pagination"></div>
        </section>

        <section class="oe-nc-comm-detail-pane" id="nc-comm-detail-pane" aria-label="{{ 'Detail'|xlt }}">
            <button type="button" class="btn btn-link btn-sm d-md-none oe-nc-comm-back" id="nc-comm-back">
                <i class="fa fa-arrow-left" aria-hidden="true"></i> {{ 'Back to list'|xlt }}
            </button>
            <div id="nc-comm-detail" class="oe-nc-comm-detail">
                <div class="oe-nc-comm-empty text-muted">
                    <p class="mb-0">{{ 'Select an item to read details.'|xlt }}</p>
                </div>
            </div>
        </section>
    </div>

    <footer class="oe-nc-comm-footer" id="nc-comm-footer">
        <button type="button" class="btn btn-primary btn-sm d-none" id="nc-comm-mark-done">{{ 'Mark done'|xlt }}</button>
        <button type="button" class="btn btn-primary btn-sm d-none" id="nc-comm-reminder-complete">{{ 'Mark completed'|xlt }}</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="nc-comm-create-reminder">{{ 'Create reminder'|xlt }}</button>
        <button type="button" class="btn btn-outline-secondary btn-sm d-none" id="nc-comm-view-log">{{ 'View log'|xlt }}</button>
        <a class="btn btn-outline-primary btn-sm" id="nc-comm-compose-link" href="{{ legacy_compose_url|attr }}" target="_top">{{ 'Compose (legacy)'|xlt }}</a>
    </footer>
</div>
{% endblock %}

{% block scripts %}
<script src="{{ assets_url }}/js/communications-hub.js?v={{ asset_version }}"></script>
<script>
(function () {
    function bootCommunications() {
        if (window.NewClinicCommunications) {
            window.NewClinicCommunications.init(document.getElementById('nc-communications-hub'));
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootCommunications);
    } else {
        bootCommunications();
    }
})();
</script>
{% endblock %}
