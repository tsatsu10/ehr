{% extends 'base.html.twig' %}

{% block page_heading_actions %}
<div class="nc-flex nc-flex-wrap nc-items-center nc-comm-toolbar" id="nc-comm-toolbar">
    <div class="nc-btn-group nc-btn-group-sm nc-mr-2 nc-mb-1" role="group" aria-label="{{ 'Lens'|xlt }}">
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary active" id="nc-comm-lens-messages" data-lens="messages">
            {{ 'Messages'|xlt }} <span class="nc-badge nc-badge-neutral" id="nc-comm-count-messages">0</span>
        </button>
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary" id="nc-comm-lens-reminders" data-lens="reminders">
            {{ 'Reminders'|xlt }} <span class="nc-badge nc-badge-neutral" id="nc-comm-count-reminders">0</span>
        </button>
    </div>
    <input type="search"
           class="nc-input nc-input-sm nc-mr-2 nc-mb-1 nc-comm-toolbar-search"
           id="nc-comm-search"
           placeholder="{{ 'Search messages…'|xlt }}"
           aria-label="{{ 'Search'|xlt }}">
    <select class="nc-select nc-select-sm nc-mr-2 nc-mb-1 nc-hidden nc-comm-toolbar-select" id="nc-comm-activity" aria-label="{{ 'Message activity'|xlt }}">
        <option value="1">{{ 'Open'|xlt }}</option>
        <option value="0">{{ 'Done'|xlt }}</option>
        <option value="all">{{ 'All'|xlt }}</option>
    </select>
    {% if can_view_all_users %}
    <div class="nc-form-check nc-form-check-inline nc-mb-1 nc-mr-2 nc-hidden" id="nc-comm-scope-wrap">
        <input type="checkbox" class="nc-form-check-input" id="nc-comm-show-all">
        <label class="nc-form-check-label nc-text-sm" for="nc-comm-show-all">{{ 'All users'|xlt }}</label>
    </div>
    {% endif %}
    {# One sort select instead of the old field × order pair — values map to
       sortby/sortorder in useCommunicationsPageHeading. #}
    <select class="nc-select nc-select-sm nc-mr-2 nc-mb-1 nc-hidden nc-comm-toolbar-select" id="nc-comm-sort" aria-label="{{ 'Sort'|xlt }}">
        <option value="date_desc">{{ 'Newest first'|xlt }}</option>
        <option value="date_asc">{{ 'Oldest first'|xlt }}</option>
        <option value="patient_az">{{ 'Patient A–Z'|xlt }}</option>
        <option value="from_az">{{ 'Sender A–Z'|xlt }}</option>
        <option value="type_az">{{ 'Type A–Z'|xlt }}</option>
    </select>
    <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-mb-1" id="nc-comm-refresh" aria-label="{{ 'Refresh'|xlt }}">
        <i class="fa fa-refresh" aria-hidden="true"></i>
    </button>
    {# Lens-scoped actions, top-right like every other desk. React toggles
       nc-hidden by lens: messages → "+ New message"; reminders → "View log"
       + "+ New reminder". #}
    <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-mb-1 nc-mr-2 nc-hidden" id="nc-comm-view-log">
        {{ 'View log'|xlt }}
    </button>
    <button type="button" class="nc-btn nc-btn-sm nc-btn-primary nc-mb-1 nc-comm-new-message" id="nc-comm-new-message">
        + {{ 'New message'|xlt }}
    </button>
    <button type="button" class="nc-btn nc-btn-sm nc-btn-primary nc-mb-1 nc-hidden" id="nc-comm-new-reminder">
        + {{ 'New reminder'|xlt }}
    </button>
</div>
{% endblock %}

{% block content %}
{% if enable_react_communications_hub|default(true) %}
<div
    data-island="communications-hub"
    data-props="{{ {
        ajaxUrl: ajax_url,
        csrfToken: csrf_token,
        canViewAllUsers: can_view_all_users ? true : false,
        initialLens: initial_lens,
        preferences: preferences,
        webroot: webroot,
        composeLaunch: compose_launch
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Communications Hub' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_communications_hub|default(true) %}
<link rel="stylesheet" href="{{ assets_url }}/css/communications-hub.css?v={{ asset_version }}">
{% include 'partials/island-assets.html.twig' %}
{% endif %}
{% endblock %}
