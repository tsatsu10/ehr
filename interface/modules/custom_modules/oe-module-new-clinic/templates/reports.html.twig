{% extends 'base.html.twig' %}

{% block page_heading_actions %}
<label class="nc-mb-0" for="nc-reports-date">{{ 'Date'|xlt }}</label>
<input type="date" class="nc-input nc-input-sm" id="nc-reports-date" style="width:auto;">
<button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary" id="nc-reports-refresh">
    {{ 'Refresh'|xlt }}
</button>
<span class="nc-text-muted nc-text-sm" id="nc-reports-updated"></span>
{% endblock %}

{% block content %}
{% if enable_react_daily_reports|default(true) %}
<div
    data-island="daily-reports"
    data-props="{{ {
        ajaxUrl: ajax_url,
        csrfToken: csrf_token,
        facilityId: desk_facility_id|default(0)|number_format(0, '', ''),
        visitBoardUrl: visit_board_url,
        canCancelVisit: can_cancel_visit ? true : false,
        canMarkUnpaid: can_mark_unpaid ? true : false,
        canRunReconciliation: can_run_reconciliation ? true : false,
        scheduledIntegrationEnabled: scheduled_integration_enabled ? true : false,
        ancillaryServicesEnabled: ancillary_services_enabled ? true : false
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Daily Reports' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_daily_reports|default(true) %}
{% include 'partials/island-assets.html.twig' %}
{% endif %}
{% endblock %}
