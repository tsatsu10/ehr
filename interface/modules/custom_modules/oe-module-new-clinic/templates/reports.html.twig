{% extends 'base.html.twig' %}

{% block page_heading_actions %}
<label class="mb-0" for="nc-reports-date">{{ 'Date'|xlt }}</label>
<input type="date" class="form-control form-control-sm" id="nc-reports-date" style="width:auto;">
<button type="button" class="btn btn-outline-primary btn-sm" id="nc-reports-refresh">
    {{ 'Refresh'|xlt }}
</button>
<span class="text-muted small" id="nc-reports-updated"></span>
{% endblock %}

{% block content %}
{% if enable_react_daily_reports|default(true) %}
<div
    data-island="daily-reports"
    data-props="{{ {
        ajaxUrl: ajax_url,
        csrfToken: csrf_token,
        facilityId: desk_facility_id|default(0)|number_format(0, '', ''),
        visitBoardUrl: visit_board_url,
        canCancelVisit: can_cancel_visit ? true : false,
        canMarkUnpaid: can_mark_unpaid ? true : false,
        canRunReconciliation: can_run_reconciliation ? true : false
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Daily Reports' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_daily_reports|default(true) %}
<link rel="stylesheet" href="{{ assets_url }}/modern/daily-reports.css?v={{ asset_version }}">
<script type="module" src="{{ assets_url }}/modern/daily-reports.js?v={{ asset_version }}"></script>
{% endif %}
{% endblock %}
