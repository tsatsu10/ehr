{% extends 'base.html.twig' %}

{% block page_subtitle %}
{% if board_profile|default('default') != 'wall' %}
<div class="oe-nc-page-heading__subtitle" id="nc-board-date"></div>
{% endif %}
{% endblock %}

{% block page_heading_actions %}
{% if board_profile|default('default') != 'wall' %}
<button type="button" class="btn btn-outline-primary btn-sm" id="nc-refresh-queue">
    {{ 'Refresh'|xlt }}
</button>
<span class="text-muted small" id="nc-board-updated"></span>
{% endif %}
{% endblock %}

{% block content %}
{% if board_profile|default('default') == 'wall' %}
<div class="oe-nc-wall-banner" id="nc-wall-now-serving" aria-live="polite"
     data-clinic-name="{{ shell.brand.clinic_name|e('html_attr') }}">
    {{ shell.brand.clinic_name|text }}
</div>
{% endif %}
{% if enable_react_visit_board|default(true) %}
<div data-island="visit-board"
     data-props="{{ {
         'ajaxUrl':     ajax_url,
         'csrfToken':   csrf_token,
         'facilityId':  desk_facility_id,
         'pollMs':      30000,
         'profile':     board_profile|default('default'),
         'privacyMode': board_profile|default('default') == 'wall',
         'canCancel':   can_cancel_visit,
         'deskUrls':    desk_urls
     }|json_encode|e('html_attr') }}"></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Visit Board' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_visit_board|default(true) %}
<link rel="stylesheet" href="{{ assets_url }}/modern/visit-board.css?v={{ asset_version }}">
<script type="module" src="{{ assets_url }}/modern/visit-board.js?v={{ asset_version }}"></script>
{% endif %}
{% endblock %}
