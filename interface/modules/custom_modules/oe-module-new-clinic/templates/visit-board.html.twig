{% extends 'base.html.twig' %}

{% block page_subtitle %}
{% if board_profile|default('default') != 'wall' %}
<div class="nc-page-heading-subtitle" id="nc-board-date"></div>
{% endif %}
{% endblock %}

{% block page_heading_actions %}
{% if board_profile|default('default') != 'wall' %}
<button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary" id="nc-refresh-queue">
    {{ 'Refresh'|xlt }}
</button>
<span class="nc-text-muted nc-text-sm" id="nc-board-updated"></span>
{% endif %}
{% endblock %}

{% block content %}
{% if board_profile|default('default') == 'wall' %}
<div class="nc-wall-banner" id="nc-wall-now-serving" aria-live="polite"
     data-clinic-name="{{ shell.brand.clinic_name|e('html_attr') }}">
    {{ shell.brand.clinic_name|text }}
</div>
{% endif %}
{% if enable_react_visit_board|default(true) %}
<div data-island="visit-board"
     data-props="{{ {
         'ajaxUrl':     ajax_url,
         'csrfToken':   csrf_token,
         'facilityId':  desk_facility_id,
         'pollMs':      queue_poll_ms|default(30000),
         'profile':     board_profile|default('default'),
         'privacyMode': board_profile|default('default') == 'wall',
         'kioskChrome': kiosk_chrome|default(false) ? true : false,
         'clinicName':  shell.brand.clinic_name|default(''),
         'canCancel':   can_cancel_visit,
         'canSendBackToDoctor': can_send_back_to_doctor,
         'deskUrls':    desk_urls
     }|json_encode|e('html_attr') }}"></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Visit Board' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_visit_board|default(true) %}
{% include 'partials/island-assets.html.twig' %}
{% endif %}
{% endblock %}
