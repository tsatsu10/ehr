{% extends 'base.html.twig' %}

{% block content %}
{% if enable_react_front_desk|default(true) %}
<div
    data-island="front-desk"
    data-props="{{ {
        ajaxUrl:                       ajax_url,
        csrfToken:                     csrf_token,
        facilityId:                    desk_facility_id|default(0)|number_format(0, '', ''),
        moduleUrl:                     module_url,
        registrationMode:              registration_mode,
        pinnedPreview:                 enable_pinned_reception_preview ? true : false,
        printQueueSlip:                print_queue_slip_on_start_visit ? true : false,
        scheduledIntegrationEnabled:   scheduled_integration_enabled ? true : false,
        appointmentsTodayCount:        appointments_today_count|default(0)|number_format(0, '', ''),
        calendarUrl:                   calendar_url
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Front Desk' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_front_desk|default(true) %}
<link rel="stylesheet" href="{{ assets_url }}/modern/front-desk.css?v={{ asset_version }}">
<link rel="stylesheet" href="{{ assets_url }}/css/registration-form.css?v={{ asset_version }}">
<script type="module" src="{{ assets_url }}/modern/front-desk.js?v={{ asset_version }}"></script>
{% endif %}
{% endblock %}
