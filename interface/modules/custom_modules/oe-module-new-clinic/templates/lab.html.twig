{% extends 'base.html.twig' %}

{% block page_subtitle %}
<div class="oe-nc-page-heading__subtitle" id="nc-lab-date"></div>
{% endblock %}

{% block page_heading_actions %}
<button type="button" class="btn btn-outline-primary btn-sm" id="nc-lab-refresh" aria-label="{{ 'Refresh'|xlt }}">
    <i class="fa fa-refresh" aria-hidden="true"></i>
</button>
{% if lab_ops_url %}
<a class="btn btn-outline-secondary btn-sm" href="{{ lab_ops_url|attr }}" target="_top">{{ 'Lab Operations'|xlt }}</a>
{% endif %}
<span class="text-muted small" id="nc-lab-updated"></span>
{% endblock %}

{% block content %}
{% if enable_react_lab_desk|default(true) %}
<div
    data-island="lab-desk"
    data-props="{{ {
        ajaxUrl:               ajax_url,
        csrfToken:             csrf_token,
        facilityId:            desk_facility_id|default(0)|number_format(0, '', ''),
        visitBoardUrl:         visit_board_url,
        labOpsUrl:             lab_ops_url,
        labOpsEnabled:         lab_ops_enabled ? true : false,
        canEnterResults:       can_enter_results ? true : false,
        canReleaseResults:     can_release_results ? true : false,
        canSkipToPayment:      can_skip_to_payment ? true : false,
        sharedDeviceWarning:   enable_shared_device_session_warning ? true : false,
        canEsignOverride:      can_esign_override ? true : false
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Lab Desk' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_lab_desk|default(true) %}
<link rel="stylesheet" href="{{ assets_url }}/modern/lab-desk.css?v={{ asset_version }}">
{% if lab_ops_enabled %}
<link rel="stylesheet" href="{{ assets_url }}/css/lab-ops.css?v={{ asset_version }}">
{% endif %}
<script type="module" src="{{ assets_url }}/modern/lab-desk.js?v={{ asset_version }}"></script>
{% endif %}
{% endblock %}
