{% extends 'base.html.twig' %}

{% block page_subtitle %}
<div class="oe-nc-page-heading__subtitle" id="nc-lab-date"></div>
{% endblock %}

{% block page_heading_actions %}
<button type="button" class="btn btn-outline-primary btn-sm" id="nc-lab-refresh">
    {{ 'Refresh'|xlt }}
</button>
{% if lab_ops_url %}
<a class="btn btn-outline-secondary btn-sm" href="{{ lab_ops_url|attr }}" target="_top">{{ 'Lab Operations'|xlt }}</a>
{% endif %}
<span class="text-muted small" id="nc-lab-updated"></span>
{% endblock %}

{% block content %}
<div id="nc-lab-desk"
     data-ajax-url="{{ ajax_url }}"
     data-csrf-token="{{ csrf_token }}"
     data-module-url="{{ module_url }}"
     data-visit-board-url="{{ visit_board_url }}"
     data-webroot="{{ webroot }}"
     data-can-skip="{{ can_skip_to_payment ? '1' : '0' }}"
     data-lab-ops-enabled="{{ lab_ops_enabled ? '1' : '0' }}"
     data-can-enter="{{ can_enter_results ? '1' : '0' }}"
     data-can-release="{{ can_release_results ? '1' : '0' }}"
     data-shared-device-warning="{{ enable_shared_device_session_warning ? '1' : '0' }}">
    <div id="nc-lab-interrupt" class="alert alert-warning d-none mb-3" role="alert">
        <div class="d-flex justify-content-between flex-wrap">
            <span id="nc-lab-interrupt-text"></span>
            <button type="button" class="btn btn-sm btn-outline-secondary ml-2" id="nc-lab-interrupt-dismiss">
                {{ 'Return to queue'|xlt }}
            </button>
        </div>
    </div>

    {% include 'partials/shared-device-session-banner.html.twig' with { prefix: 'nc-lab' } only %}

    <div class="row">
        <div class="col-lg-4 mb-3">
            <div class="nc-lab-queue-panel">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong>{{ 'Lab queue'|xlt }}</strong>
                    <span class="text-muted small" id="nc-lab-counts"></span>
                </div>
                <div id="nc-lab-queue-list"></div>
                <p class="text-muted small mt-3 mb-0">
                    {{ 'Skipped lab patients appear on Visit Board under Pharmacy or Payment.'|xlt }}
                </p>
            </div>
        </div>

        <div class="col-lg-8 mb-3">
            <div id="nc-lab-active-pane">
                <div class="card">
                    <div class="card-body text-muted text-center py-5">
                        <em>{{ 'Select a patient from the lab queue.'|xlt }}</em>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="nc-lab-skip-modal" tabindex="-1" role="dialog"
     aria-labelledby="nc-lab-skip-title" aria-modal="true" aria-hidden="true" style="display:none;">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="nc-lab-skip-title">{{ 'Skip lab queue'|xlt }}</h5>
                <button type="button" class="close nc-modal-close" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p id="nc-lab-skip-patient" class="mb-2"></p>
                <p class="text-muted small">{{ 'Sends visit to payment, bypassing lab.'|xlt }}</p>
                <div class="form-group">
                    <label for="nc-lab-skip-reason">{{ 'Reason (required)'|xlt }}</label>
                    <textarea class="form-control" id="nc-lab-skip-reason" rows="2"></textarea>
                </div>
                <div class="alert alert-danger mt-2 d-none" id="nc-lab-skip-error"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary nc-modal-close">{{ 'Cancel'|xlt }}</button>
                <button type="button" class="btn btn-warning" id="nc-lab-skip-confirm">{{ 'Skip to payment'|xlt }}</button>
            </div>
        </div>
    </div>
</div>
<div class="modal-backdrop fade" id="nc-lab-modal-backdrop" style="display:none;"></div>
{% endblock %}

{% block scripts %}
<script src="{{ assets_url }}/js/modal-a11y.js?v={{ asset_version }}"></script>
{% if lab_ops_enabled %}
<script src="{{ assets_url }}/js/lab-result-validation.js?v={{ asset_version }}"></script>
<script src="{{ assets_url }}/js/lab-ops-entry.js?v={{ asset_version }}"></script>
{% endif %}
<script src="{{ assets_url }}/js/lab.js?v={{ asset_version }}"></script>
<script>
(function () {
    function bootLab() {
        if (window.NewClinicLab) {
            window.NewClinicLab.init(document.getElementById('nc-lab-desk'));
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootLab);
    } else {
        bootLab();
    }
})();
</script>
{% endblock %}
