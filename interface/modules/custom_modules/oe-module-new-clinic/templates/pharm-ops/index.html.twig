{% extends 'base.html.twig' %}

{% block page_heading_actions %}
<div class="nc-flex nc-flex-wrap nc-items-center nc-pharmops-toolbar" id="nc-pharmops-toolbar">
    <div class="nc-btn-group nc-btn-group-sm nc-mr-2 nc-mb-1" role="group" aria-label="{{ 'Worklist tabs'|xlt }}">
        <button type="button"
                class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'pending_dispense' %} active{% endif %}"
                id="nc-pharmops-tab-pending">
            {{ 'Pending dispense'|xlt }} <span class="nc-badge nc-badge-neutral" id="nc-pharmops-count-pending">0</span>
        </button>
        <button type="button"
                class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'low_stock' %} active{% endif %}"
                id="nc-pharmops-tab-lowstock">
            {{ 'Low stock'|xlt }} <span class="nc-badge nc-badge-neutral" id="nc-pharmops-count-lowstock">0</span>
        </button>
        <button type="button"
                class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'write_off' %} active{% endif %}"
                id="nc-pharmops-tab-writeoff">
            {{ 'Write-off'|xlt }} <span class="nc-badge nc-badge-neutral" id="nc-pharmops-count-writeoff">0</span>
        </button>
        <button type="button"
                class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'inventory' %} active{% endif %}"
                id="nc-pharmops-tab-inventory">
            {{ 'Inventory'|xlt }}
        </button>
        <button type="button"
                class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'reports' %} active{% endif %}"
                id="nc-pharmops-tab-reports">
            {{ 'Reports'|xlt }}
        </button>
    </div>
    <input type="date"
           class="nc-input nc-input-sm nc-mr-2 nc-mb-1"
           id="nc-pharmops-date"
           aria-label="{{ 'Worklist date'|xlt }}"
           style="width:auto;">
    <div class="nc-form-check nc-form-check-inline nc-mb-1 nc-mr-2" id="nc-pharmops-urgent-wrap">
        <input type="checkbox" class="nc-form-check-input" id="nc-pharmops-urgent-first" checked>
        <label class="nc-form-check-label nc-text-sm" for="nc-pharmops-urgent-first">{{ 'Urgent first'|xlt }}</label>
    </div>
    <a class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-mb-1 nc-mr-1" href="{{ pharmacy_desk_url|attr }}">{{ 'Pharmacy Desk'|xlt }}</a>
    <a class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-mb-1 nc-mr-1" href="{{ visit_board_url|attr }}">{{ 'Visit Board'|xlt }}</a>
    {% if can_dispense %}
    <button type="button" class="nc-btn nc-btn-sm nc-btn-primary nc-mb-1 nc-mr-1" id="nc-pharmops-sell-otc">
        {{ 'Sell OTC'|xlt }}
    </button>
    {% endif %}
    {% if can_receive %}
    <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary nc-mb-1 nc-mr-1" id="nc-pharmops-receive">
        {{ 'Receive stock'|xlt }}
    </button>
    {% endif %}
    {% if can_manage_catalog %}
    <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-mb-1 nc-mr-1" id="nc-pharmops-setup" title="{{ 'Pharmacy setup'|xlt }}">
        <i class="fa fa-cog" aria-hidden="true"></i>
        <span class="nc-sr-only">{{ 'Setup'|xlt }}</span>
    </button>
    {% endif %}
    {# Advanced (core) dropdown removed — every item is now a native surface:
       Inventory management → Inventory tab, the four inventory reports +
       prescriptions → Reports tab, Add drug → Setup → catalog. No core links. #}
    <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-mb-1" id="nc-pharmops-refresh" aria-label="{{ 'Refresh'|xlt }}">
        <i class="fa fa-refresh" aria-hidden="true"></i>
    </button>
    <span class="nc-text-muted nc-text-sm nc-mb-1" id="nc-pharmops-updated"></span>
</div>
{% endblock %}

{% block content %}
{% if enable_react_pharm_ops|default(true) %}
<div
    data-island="pharm-ops"
    data-props="{{ {
        ajaxUrl: ajax_url,
        csrfToken: csrf_token,
        moduleUrl: module_url,
        pharmacyDeskUrl: pharmacy_desk_url,
        visitBoardUrl: visit_board_url,
        facilityId: desk_facility_id|default(0)|number_format(0, '', ''),
        initialTab: initial_tab,
        canDispense: can_dispense ? true : false,
        canReceive: can_receive ? true : false,
        canDestroy: can_destroy ? true : false,
        canManageCatalog: can_manage_catalog ? true : false,
        canViewReports: true,
        webroot: webroot
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Pharmacy Operations' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_pharm_ops|default(true) %}
<link rel="stylesheet" href="{{ assets_url }}/css/pharm-ops.css?v={{ asset_version }}">
{% include 'partials/island-assets.html.twig' %}
{% endif %}
{% endblock %}
