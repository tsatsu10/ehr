{# progress-bar — label + % + accessible track #}
<div class="nc-progress-bar nc-progress-bar-{{ variant|default('info') }}"
     role="progressbar"
     aria-valuenow="{{ value|default(0) }}"
     aria-valuemin="0"
     aria-valuemax="100"
     aria-label="{{ label|default('Progress')|xlt }}">
    <div class="nc-progress-bar-header">
        <span class="nc-progress-bar-label">{{ label|default('Profile complete')|xlt }}</span>
        <span class="nc-progress-bar-value">{{ value|default(0) }}%</span>
    </div>
    <div class="nc-progress-bar-track">
        <div class="nc-progress-bar-fill" style="width: {{ value|default(0) }}%"></div>
    </div>
</div>
