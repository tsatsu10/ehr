{# progress-bar — label + % + accessible track #}
<div class="oe-nc-progress-bar oe-nc-progress-bar--{{ variant|default('info') }}"
     role="progressbar"
     aria-valuenow="{{ value|default(0) }}"
     aria-valuemin="0"
     aria-valuemax="100"
     aria-label="{{ label|default('Progress')|xlt }}">
    <div class="oe-nc-progress-bar__header">
        <span class="oe-nc-progress-bar__label">{{ label|default('Profile complete')|xlt }}</span>
        <span class="oe-nc-progress-bar__value">{{ value|default(0) }}%</span>
    </div>
    <div class="oe-nc-progress-bar__track">
        <div class="oe-nc-progress-bar__fill" style="width: {{ value|default(0) }}%"></div>
    </div>
</div>
