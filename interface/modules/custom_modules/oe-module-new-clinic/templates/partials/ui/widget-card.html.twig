{# widget-card — header + body shell #}
<div class="nc-widget-card{% if class is defined %} {{ class }}{% endif %}"{% if id is defined %} id="{{ id }}"{% endif %}>
    {% if title is defined %}
        <div class="nc-widget-card-header">
            <h2 class="nc-widget-card-title">{{ title|xlt }}</h2>
            {% if actions is defined %}
                <div class="nc-widget-card-actions">{{ actions|raw }}</div>
            {% endif %}
        </div>
    {% endif %}
    <div class="nc-widget-card-body nc-widget-card-body-{{ body_pad|default('flush') }}">
        {% block body %}{% endblock %}
    </div>
</div>
