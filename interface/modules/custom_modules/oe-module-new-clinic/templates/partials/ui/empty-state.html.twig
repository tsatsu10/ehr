<div class="oe-nc-empty-state">
    <div class="oe-nc-empty-state__icon">
        <i class="fa {{ icon|default('fa-user') }}" aria-hidden="true"></i>
    </div>
    <div class="oe-nc-empty-state__title">{{ title|xlt }}</div>
    <p class="mb-0 small">{{ message|xlt }}</p>
    {% if cta is defined %}
        <div class="mt-3">{{ cta|raw }}</div>
    {% endif %}
</div>
