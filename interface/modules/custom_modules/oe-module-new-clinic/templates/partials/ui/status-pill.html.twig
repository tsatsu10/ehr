{# status-pill — shape + label + color (never color-only) #}
<span class="nc-status-pill nc-status-pill-{{ variant|default('neutral') }}">
    {% if show_dot|default(true) %}
        <span class="nc-status-pill-dot" aria-hidden="true"></span>
    {% endif %}
    <span>{{ label|xlt }}</span>
</span>
