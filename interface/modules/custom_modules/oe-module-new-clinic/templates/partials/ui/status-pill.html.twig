{# status-pill — shape + label + color (never color-only) #}
<span class="oe-nc-status-pill oe-nc-status-pill--{{ variant|default('neutral') }}">
    {% if show_dot|default(true) %}
        <span class="oe-nc-status-pill__dot" aria-hidden="true"></span>
    {% endif %}
    <span>{{ label|xlt }}</span>
</span>
