{# T1-F18 — legacy patient context strip on stock chart pages #}
<link rel="stylesheet" href="{{ asset_css_url|attr }}">
<div id="legacy-patient-context-strip"
     class="oe-nc-legacy-strip"
     data-host="legacy_chart"
     role="region"
     aria-label="{{ 'Patient context'|xla }}">
    <div class="oe-nc-legacy-strip__inner container-fluid py-2">
        <div class="oe-nc-legacy-strip__row">
            <div class="oe-nc-legacy-strip__avatar" aria-hidden="true">{{ initials|text }}</div>
            <div class="oe-nc-legacy-strip__identity">
                <strong class="oe-nc-legacy-strip__name">{{ display_name|text }}</strong>
                <span class="oe-nc-legacy-strip__meta">
                    {{ sex|text }} · {{ age_years|text }}y · {{ 'MRN'|xlt }} {{ mrn|text }}
                    {% if dob_label %}
                        · {{ 'DOB'|xlt }} {{ dob_label|text }}
                        {% if dob_estimated %}
                            <span class="badge badge-warning ml-1">{{ 'Est.'|xlt }}</span>
                        {% endif %}
                    {% endif %}
                </span>
                {% if visit_state_label and queue_number %}
                    <div class="oe-nc-legacy-strip__visit mt-1">
                        <span class="oe-nc-status-pill oe-nc-status-pill--info">
                            <span class="oe-nc-status-pill__dot" aria-hidden="true"></span>
                            <span>{{ visit_state_label|text }} · {{ 'Queue'|xlt }} #{{ queue_number|text }}</span>
                        </span>
                    </div>
                {% endif %}
                {% if allergy_chips|length %}
                    <div class="oe-nc-legacy-strip__allergies mt-1">
                        {% for allergy in allergy_chips %}
                            <span class="badge badge-danger mr-1">{{ allergy|text }}</span>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            <div class="oe-nc-legacy-strip__actions text-right">
                {% if enable_chart_depth %}
                    <a class="btn btn-sm btn-outline-primary" href="{{ module_chart_url|attr }}" target="_top">
                        {{ 'Open chart'|xlt }}
                    </a>
                {% endif %}
                {% if show_desk_return %}
                    <a class="btn btn-sm btn-outline-secondary d-none oe-nc-legacy-strip__desk-return" href="#" target="_top"></a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% if show_desk_return %}
<script>
(function () {
    var link = document.querySelector('.oe-nc-legacy-strip__desk-return');
    if (!link) {
        return;
    }
    var pagePid = {{ pid|json_encode|raw }};
    var desks = [
        { key: 'doctor_desk_active_visit_id', url: {{ (webroot ~ '/interface/modules/custom_modules/oe-module-new-clinic/public/doctor.php')|json_encode|raw }}, label: {{ 'Return to Doctor Desk'|xlj }} },
        { key: 'triage_desk_active_visit_id', url: {{ (webroot ~ '/interface/modules/custom_modules/oe-module-new-clinic/public/triage.php')|json_encode|raw }}, label: {{ 'Return to Triage'|xlj }} },
        { key: 'lab_desk_active_visit_id', url: {{ (webroot ~ '/interface/modules/custom_modules/oe-module-new-clinic/public/lab.php')|json_encode|raw }}, label: {{ 'Return to Lab Desk'|xlj }} },
        { key: 'pharmacy_desk_active_visit_id', url: {{ (webroot ~ '/interface/modules/custom_modules/oe-module-new-clinic/public/pharmacy.php')|json_encode|raw }}, label: {{ 'Return to Pharmacy Desk'|xlj }} }
    ];
    desks.forEach(function (desk) {
        try {
            var raw = window.sessionStorage.getItem(desk.key);
            if (!raw) {
                return;
            }
            var stored = JSON.parse(raw);
            if (stored.pid && pagePid && parseInt(String(stored.pid), 10) !== pagePid) {
                link.href = desk.url;
                link.textContent = desk.label;
                link.classList.remove('d-none');
            }
        } catch (e) {
            return;
        }
    });
})();
</script>
{% endif %}
