{# T1-F20b — History editor shell (V1.1-HIST-WRAP) #}
<link rel="stylesheet" href="{{ asset_css_url|attr }}">
{% if legacy_strip_html %}
    {{ legacy_strip_html|raw }}
{% endif %}
<header id="nc-history-editor-wrap"
        class="nc-history-editor-wrap-header"
        role="banner"
        aria-label="{{ 'History editor'|xla }}">
    <div class="nc-history-editor-wrap-inner nc-container-fluid nc-py-2">
        <div class="nc-history-editor-wrap-top">
            <div class="nc-history-editor-wrap-brand">
                <strong class="nc-history-editor-wrap-clinic">{{ clinic_name|text }}</strong>
                {% if role_label %}
                    <span class="nc-history-editor-wrap-role">{{ role_label|text }}</span>
                {% endif %}
                {% if today_label %}
                    <span class="nc-history-editor-wrap-date">{{ today_label|text }}</span>
                {% endif %}
            </div>
            {% if back_url %}
                <a class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary nc-history-editor-wrap-back-top"
                   href="{{ back_url|attr }}"
                   target="_top">
                    {{ back_label|text }}
                </a>
            {% endif %}
        </div>
        <div class="nc-history-editor-wrap-title-row">
            <h1 class="nc-history-editor-wrap-title h5 nc-mb-0">{{ page_title|text }}</h1>
            <nav class="nc-history-editor-wrap-breadcrumb nc-text-sm nc-text-muted" aria-label="{{ 'Breadcrumb'|xla }}">
                <span>{{ breadcrumb_chart|text }}</span>
                <span aria-hidden="true"> › </span>
                <span>{{ breadcrumb_clinical|text }}</span>
                <span aria-hidden="true"> › </span>
                <span>{{ breadcrumb_edit|text }}</span>
            </nav>
        </div>
    </div>
</header>
