{% extends 'base.html.twig' %}

{% block page_heading_actions %}
<div class="d-flex flex-wrap align-items-center oe-nc-labops-toolbar" id="nc-labops-toolbar">
    <div class="btn-group btn-group-sm mr-2 mb-1" role="group" aria-label="{{ 'Worklist tabs'|xlt }}">
        <button type="button"
                class="btn btn-outline-primary{% if initial_tab == 'pending' %} active{% endif %}"
                id="nc-labops-tab-pending">
            {{ 'Pending'|xlt }} <span class="badge badge-light" id="nc-labops-count-pending">0</span>
        </button>
        <button type="button"
                class="btn btn-outline-primary{% if initial_tab == 'in_progress' %} active{% endif %}"
                id="nc-labops-tab-progress">
            {{ 'In progress'|xlt }} <span class="badge badge-light" id="nc-labops-count-progress">0</span>
        </button>
        <button type="button"
                class="btn btn-outline-primary{% if initial_tab == 'send_out' %} active{% endif %}"
                id="nc-labops-tab-sendout">
            {{ 'Send-out'|xlt }} <span class="badge badge-light" id="nc-labops-count-sendout">0</span>
        </button>
    </div>
    <input type="date"
           class="form-control form-control-sm mr-2 mb-1"
           id="nc-labops-date"
           aria-label="{{ 'Worklist date'|xlt }}"
           style="width:auto;">
    <select class="form-control form-control-sm mr-2 mb-1"
            id="nc-labops-fulfillment"
            aria-label="{{ 'Fulfillment filter'|xlt }}"
            style="width:auto;">
        <option value="all">{{ 'All fulfillment'|xlt }}</option>
        <option value="in_house">{{ 'In-house'|xlt }}</option>
        <option value="send_out">{{ 'Send-out'|xlt }}</option>
    </select>
    <div class="form-check form-check-inline mb-1 mr-2">
        <input type="checkbox" class="form-check-input" id="nc-labops-urgent-first" checked>
        <label class="form-check-label small" for="nc-labops-urgent-first">{{ 'Urgent first'|xlt }}</label>
    </div>
    <a class="btn btn-outline-secondary btn-sm mb-1 mr-1" href="{{ lab_desk_url|attr }}">{{ 'Lab Desk'|xlt }}</a>
    <a class="btn btn-outline-secondary btn-sm mb-1 mr-1" href="{{ visit_board_url|attr }}">{{ 'Visit Board'|xlt }}</a>
    <button type="button" class="btn btn-outline-secondary btn-sm mb-1" id="nc-labops-refresh" aria-label="{{ 'Refresh'|xlt }}">
        <i class="fa fa-refresh" aria-hidden="true"></i>
    </button>
    <span class="text-muted small mb-1" id="nc-labops-updated"></span>
</div>
{% endblock %}

{% block content %}
{% if enable_react_lab_ops|default(true) %}
<div
    data-island="lab-ops"
    data-props="{{ {
        ajaxUrl: ajax_url,
        csrfToken: csrf_token,
        moduleUrl: module_url,
        labDeskUrl: lab_desk_url,
        visitBoardUrl: visit_board_url,
        facilityId: desk_facility_id|default(0)|number_format(0, '', ''),
        initialTab: initial_tab,
        canEnter: can_enter ? true : false,
        canRelease: can_release ? true : false,
        canManageCatalog: can_manage_catalog ? true : false,
        canShowAdvanced: can_show_advanced ? true : false,
        webroot: webroot
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Lab Operations' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_lab_ops|default(true) %}
<link rel="stylesheet" href="{{ assets_url }}/css/lab-ops.css?v={{ asset_version }}">
{% include 'partials/island-assets.html.twig' %}
{% endif %}
{% endblock %}
