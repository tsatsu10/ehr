{% extends 'base.html.twig' %}

{% block page_heading_actions %}
<div class="d-flex flex-wrap align-items-center oe-nc-reporthub-toolbar" id="nc-reporthub-toolbar">
    <div class="btn-group btn-group-sm mr-2 mb-1" role="group" aria-label="{{ 'Reporting lenses'|xlt }}">
        {% if can_today %}
        <button type="button" class="btn btn-outline-primary{% if initial_tab == 'today' %} active{% endif %}" data-tab="today">
            {{ 'Today'|xlt }}
        </button>
        {% endif %}
        {% if can_clinical %}
        <button type="button" class="btn btn-outline-primary{% if initial_tab == 'clinical' %} active{% endif %}" data-tab="clinical">
            {{ 'Clinical'|xlt }}
        </button>
        {% endif %}
        {% if can_pharmacy %}
        <button type="button" class="btn btn-outline-primary{% if initial_tab == 'pharmacy' %} active{% endif %}" data-tab="pharmacy">
            {{ 'Pharmacy'|xlt }}
        </button>
        {% endif %}
        {% if can_financial %}
        <button type="button" class="btn btn-outline-primary{% if initial_tab == 'financial' %} active{% endif %}" data-tab="financial">
            {{ 'Financial'|xlt }}
        </button>
        {% endif %}
        {% if can_public_health %}
        <button type="button" class="btn btn-outline-primary{% if initial_tab == 'public_health' %} active{% endif %}" data-tab="public_health">
            {{ 'Public health'|xlt }}
        </button>
        {% endif %}
        {% if can_audit %}
        <button type="button" class="btn btn-outline-primary{% if initial_tab == 'audit' %} active{% endif %}" data-tab="audit">
            {{ 'Audit'|xlt }}
        </button>
        {% endif %}
    </div>
    <span class="text-muted small mb-1 mr-2" id="nc-reporthub-kpis"></span>
    <a class="btn btn-outline-secondary btn-sm mb-1 mr-1" href="{{ visit_board_url|attr }}">{{ 'Visit Board'|xlt }}</a>
    {% if can_show_advanced %}
    <div class="dropdown d-inline-block mb-1 mr-1">
        <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            {{ 'Advanced (OpenEMR)'|xlt }}
        </button>
        <div class="dropdown-menu dropdown-menu-right">
            <a class="dropdown-item" href="{{ webroot }}/interface/reports/report.php" target="_top">{{ 'Stock Reports menu'|xlt }}</a>
            <a class="dropdown-item" href="{{ reports_url|attr }}" target="_top">{{ 'Daily Reports (M7)'|xlt }}</a>
        </div>
    </div>
    {% endif %}
    <button type="button" class="btn btn-outline-secondary btn-sm mb-1" id="nc-reporthub-refresh" aria-label="{{ 'Refresh'|xlt }}">
        <i class="fa fa-refresh" aria-hidden="true"></i>
    </button>
    <span class="text-muted small mb-1" id="nc-reporthub-updated"></span>
</div>
{% endblock %}

{% block content %}
{% if enable_react_report_hub|default(true) %}
<div
    id="nc-report-hub"
    data-island="report-hub"
    data-props="{{ {
        ajaxUrl: ajax_url,
        csrfToken: csrf_token,
        moduleUrl: module_url,
        reportsUrl: reports_url,
        visitBoardUrl: visit_board_url,
        billOpsUrl: bill_ops_url,
        pharmOpsUrl: pharm_ops_url,
        facilityId: desk_facility_id|default(0)|number_format(0, '', ''),
        initialTab: initial_tab,
        canToday: can_today ? true : false,
        canClinical: can_clinical ? true : false,
        canPharmacy: can_pharmacy ? true : false,
        canFinancial: can_financial ? true : false,
        canPublicHealth: can_public_health ? true : false,
        canAudit: can_audit ? true : false,
        canShowAdvanced: can_show_advanced ? true : false,
        webroot: webroot
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Reporting Hub' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_report_hub|default(true) %}
<script type="module" src="{{ assets_url }}/modern/report-hub.js?v={{ asset_version }}"></script>
{% endif %}
{% endblock %}
