{% extends 'base.html.twig' %}

{% block page_heading_actions %}
<div class="nc-flex nc-flex-wrap nc-items-center nc-reporthub-toolbar" id="nc-reporthub-toolbar">
    <div class="nc-btn-group nc-btn-group-sm nc-mr-2 nc-mb-1" role="group" aria-label="{{ 'Reporting lenses'|xlt }}">
        {% if can_today %}
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'today' %} active{% endif %}" data-tab="today">
            {{ 'Today'|xlt }}
        </button>
        {% endif %}
        {% if can_clinical %}
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'clinical' %} active{% endif %}" data-tab="clinical">
            {{ 'Clinical'|xlt }}
        </button>
        {% endif %}
        {% if can_pharmacy %}
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'pharmacy' %} active{% endif %}" data-tab="pharmacy">
            {{ 'Pharmacy'|xlt }}
        </button>
        {% endif %}
        {% if can_financial %}
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'financial' %} active{% endif %}" data-tab="financial">
            {{ 'Financial'|xlt }}
        </button>
        {% endif %}
        {% if can_public_health %}
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'public_health' %} active{% endif %}" data-tab="public_health">
            {{ 'Public health'|xlt }}
        </button>
        {% endif %}
        {% if can_audit %}
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary{% if initial_tab == 'audit' %} active{% endif %}" data-tab="audit">
            {{ 'Audit'|xlt }}
        </button>
        {% endif %}
    </div>
    <span class="nc-text-muted nc-text-sm nc-mb-1 nc-mr-2" id="nc-reporthub-kpis"></span>
    <a class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-mb-1 nc-mr-1" href="{{ visit_board_url|attr }}">{{ 'Visit Board'|xlt }}</a>
    {% if can_show_advanced %}
    <div class="nc-dropdown nc-inline-block nc-mb-1 nc-mr-1">
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-dropdown-toggle" data-nc-dropdown-toggle aria-haspopup="true" aria-expanded="false">
            {{ 'Advanced (OpenEMR)'|xlt }}
        </button>
        <div class="nc-dropdown-menu nc-dropdown-menu-right">
            <a class="nc-dropdown-item" href="{{ webroot }}/interface/reports/report.php" data-report-key="hub_advanced_stock_reports" target="_top">{{ 'Stock Reports menu'|xlt }}</a>
            <a class="nc-dropdown-item" href="{{ reports_url|attr }}" data-report-key="hub_advanced_daily_reports" target="_top">{{ 'Daily Reports (M7)'|xlt }}</a>
        </div>
    </div>
    {% endif %}
    <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-mb-1" id="nc-reporthub-refresh" aria-label="{{ 'Refresh'|xlt }}">
        <i class="fa fa-refresh" aria-hidden="true"></i>
    </button>
    <span class="nc-text-muted nc-text-sm nc-mb-1" id="nc-reporthub-updated"></span>
</div>
{% endblock %}

{% block content %}
{% if enable_react_report_hub|default(true) %}
<div
    id="nc-report-hub"
    data-island="report-hub"
    data-props="{{ {
        ajaxUrl: ajax_url,
        csrfToken: csrf_token,
        moduleUrl: module_url,
        reportsUrl: reports_url,
        visitBoardUrl: visit_board_url,
        frontDeskUrl: front_desk_url,
        billOpsUrl: bill_ops_url,
        pharmOpsUrl: pharm_ops_url,
        cashierUrl: cashier_url,
        chartUrlBase: chart_url_base,
        billingThreshold: billing_threshold|default(70)|number_format(0, '', ''),
        facilityId: desk_facility_id|default(0)|number_format(0, '', ''),
        initialTab: initial_tab,
        canToday: can_today ? true : false,
        canClinical: can_clinical ? true : false,
        canPharmacy: can_pharmacy ? true : false,
        canFinancial: can_financial ? true : false,
        canPublicHealth: can_public_health ? true : false,
        canAudit: can_audit ? true : false,
        canShowAdvanced: can_show_advanced ? true : false,
        canCancelVisit: can_cancel_visit ? true : false,
        canMarkUnpaid: can_mark_unpaid ? true : false,
        canRunReconciliation: can_run_reconciliation ? true : false,
        scheduledIntegrationEnabled: scheduled_integration_enabled ? true : false,
        canStartVisit: can_start_visit ? true : false,
        canBillOpsCorrect: can_bill_ops_correct ? true : false,
        canBillOpsPayment: can_bill_ops_payment ? true : false,
        canBillOpsClose: can_bill_ops_close ? true : false,
        canBillOpsOutstanding: can_bill_ops_outstanding ? true : false,
        canBillOpsInsurance: can_bill_ops_insurance ? true : false,
        reopenOnCorrection: reopen_on_correction ? true : false,
        currencyFormat: currency_format|default({}),
        runbooks: report_runbooks|default([]),
        webroot: webroot
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Reporting Hub' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_report_hub|default(true) %}
{% include 'partials/island-assets.html.twig' %}
{% endif %}
{% endblock %}
