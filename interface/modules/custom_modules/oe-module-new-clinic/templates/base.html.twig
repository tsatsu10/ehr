<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title|xlt }}</title>
    {{ header_html|raw }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@500;600;700&family=Noto+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ assets_url }}/css/tokens.css?v={{ asset_version }}">
    <link rel="stylesheet" href="{{ assets_url }}/css/shell.css?v={{ asset_version }}">
    <link rel="stylesheet" href="{{ assets_url }}/css/components.css?v={{ asset_version }}">
    <link rel="stylesheet" href="{{ assets_url }}/css/new-clinic.css?v={{ asset_version }}">
</head>
<body class="body_top">
<div id="oe-nc-t1"
     class="oe-nc-t1{% if shell_minimal|default(false) %} oe-nc-t1--shell-minimal{% endif %}{% if shell_embed|default(false) %} oe-nc-t1--embed{% endif %}{% if shell_desk_focus|default(false) %} oe-nc-t1--desk-focus{% endif %}"
     data-role-accent="{{ shell.role.accent }}"
     data-ajax-url="{{ ajax_url }}"
     data-csrf-token="{{ csrf_token }}"
     data-facility-id="{{ desk_facility_id }}"
     data-queue-poll-ms="{{ queue_poll_ms|default(30000) }}">

    {% if not shell_minimal|default(false) %}
    <div class="oe-nc-sidebar-backdrop" id="oe-nc-sidebar-backdrop" hidden aria-hidden="true"></div>

    <aside class="oe-nc-sidebar" id="oe-nc-sidebar" aria-label="{{ 'Clinic navigation'|xlt }}">
        <div class="oe-nc-sidebar__brand">
            <div class="oe-nc-brand">
                {% if shell.brand.logo_url %}
                    <img src="{{ shell.brand.logo_url|attr }}" alt="" class="oe-nc-brand__logo">
                {% else %}
                    <span class="oe-nc-brand__initials" aria-hidden="true">{{ shell.brand.initials }}</span>
                {% endif %}
                <div class="oe-nc-brand__text oe-nc-sidebar__expand-only">
                    <p class="oe-nc-brand__name mb-0">{{ shell.brand.clinic_name|text }}</p>
                    {% if shell.brand.show_facility %}
                        <div class="oe-nc-brand__facility">{{ shell.brand.facility_name|text }}</div>
                    {% endif %}
                </div>
            </div>
            <button type="button"
                    class="btn btn-link btn-sm oe-nc-sidebar__close d-lg-none"
                    id="oe-nc-sidebar-close"
                    aria-label="{{ 'Close menu'|xlt }}">
                <i class="fa fa-times" aria-hidden="true"></i>
            </button>
        </div>

        <div class="oe-nc-brand__date oe-nc-sidebar__expand-only px-3 pb-2" id="oe-nc-today-label">{{ shell.today_label|text }}</div>

        <nav class="oe-nc-sidebar__nav" aria-label="{{ 'Module pages'|xlt }}">
            {% for group in shell.nav_groups %}
                <div class="oe-nc-sidebar__group" data-nav-group="{{ group.key }}">
                    <div class="oe-nc-sidebar__group-label oe-nc-sidebar__expand-only" id="oe-nc-nav-group-{{ group.key }}">
                        {{ group.label }}
                    </div>
                    <ul class="oe-nc-sidebar__list" role="list" aria-labelledby="oe-nc-nav-group-{{ group.key }}">
                        {% for item in group.items %}
                            <li role="listitem">
                                <a href="{{ item.url|attr }}"
                                   class="oe-nc-sidebar__link{% if item.active %} is-active{% endif %}"
                                   target="_top"
                                   data-nav-id="{{ item.id }}"
                                   {% if item.badge_key %}data-badge-key="{{ item.badge_key }}"{% endif %}
                                   {% if item.active %}aria-current="page"{% endif %}
                                   title="{{ item.label }}">
                                    <span class="oe-nc-sidebar__link-icon" aria-hidden="true">
                                        <i class="fa {{ item.icon }}"></i>
                                    </span>
                                    <span class="oe-nc-sidebar__link-label oe-nc-sidebar__expand-only">{{ item.label }}</span>
                                    {% if item.badge_key %}
                                        <span class="oe-nc-sidebar__badge oe-nc-sidebar__expand-only{% if item.badge_count == 0 %} is-zero{% endif %}"
                                              data-badge-count>{{ item.badge_count }}</span>
                                    {% endif %}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% endfor %}
        </nav>

        <div class="oe-nc-sidebar__footer">
            <details class="oe-nc-queue-kpi oe-nc-sidebar__expand-only"
                      id="oe-nc-queue-stats"
                      aria-label="{{ 'Today\'s queue counts'|xlt }}">
                <summary class="oe-nc-queue-kpi__summary">
                    <span class="oe-nc-queue-kpi__summary-label">{{ 'Queue'|xlt }}</span>
                    <span class="oe-nc-queue-kpi__summary-active">
                        <span data-queue-active-total>{{ shell.queue_active_total }}</span>
                        {{ 'active'|xlt }}
                    </span>
                </summary>
                <div class="oe-nc-queue-kpi__chips" aria-live="polite">
                    {% for stat in shell.queue_stats %}
                        <span class="oe-nc-queue-kpi__chip{% if stat.key == 'done' %} oe-nc-queue-kpi__chip--muted{% endif %}"
                              data-stat-key="{{ stat.key }}"
                              title="{{ stat.label }}">
                            <span class="oe-nc-queue-kpi__chip-count" data-stat-count>{{ stat.count }}</span>
                            <span class="oe-nc-queue-kpi__chip-label">{{ stat.short_label }}</span>
                        </span>
                    {% endfor %}
                </div>
            </details>

            <div class="oe-nc-queue-kpi__mini oe-nc-sidebar__collapse-only"
                 id="oe-nc-queue-stats-mini"
                 aria-live="polite"
                 title="{{ 'Patients still in workflow'|xlt }}">
                <span class="oe-nc-queue-kpi__mini-label">{{ 'Active'|xlt }}</span>
                <span class="oe-nc-queue-kpi__mini-count" data-queue-active-total>{{ shell.queue_active_total }}</span>
            </div>

            <div class="dropdown oe-nc-sidebar__role oe-nc-profile-card">
                <button type="button"
                        class="oe-nc-profile-card__trigger dropdown-toggle w-100"
                        id="oe-nc-role-pill"
                        data-toggle="dropdown"
                        aria-haspopup="true"
                        aria-expanded="false"
                        aria-label="{{ 'Active role menu'|xlt }}">
                    <span class="oe-nc-profile-card__avatar-wrap" aria-hidden="true">
                        <span class="oe-nc-profile-card__avatar">{{ shell.user.initials }}</span>
                    </span>
                    <span class="oe-nc-profile-card__body oe-nc-sidebar__expand-only">
                        <span class="oe-nc-profile-card__name">
                            {{ shell.user.first_name|text }}{% if shell.user.last_name %} {{ shell.user.last_name|text }}{% endif %}
                        </span>
                        <span class="oe-nc-profile-card__role">{{ shell.role.label }}</span>
                    </span>
                    <span class="oe-nc-profile-card__caret oe-nc-sidebar__expand-only" aria-hidden="true">
                        <i class="fa fa-chevron-down"></i>
                    </span>
                </button>
                <div class="dropdown-menu oe-nc-role-menu oe-nc-profile-card__menu" aria-labelledby="oe-nc-role-pill">
                    <div class="oe-nc-profile-card__menu-header dropdown-header">
                        <span class="oe-nc-profile-card__menu-name">
                            {{ shell.user.first_name|text }}{% if shell.user.last_name %} {{ shell.user.last_name|text }}{% endif %}
                        </span>
                        <span class="oe-nc-profile-card__menu-role">{{ shell.role.label }}</span>
                    </div>
                    {% if shell.role.available|length > 1 %}
                        <div class="dropdown-header oe-nc-role-switch__heading">{{ 'Switch role'|xlt }}</div>
                        <p class="oe-nc-role-switch__hint">{{ 'Shared device — pick who you are at this station.'|xlt }}</p>
                        {% for role in shell.role.available %}
                            <button type="button"
                                    class="dropdown-item oe-nc-role-switch-item{% if role.is_active %} is-active{% endif %}"
                                    data-role-aco="{{ role.aco }}"
                                    {% if role.is_active %}aria-current="true" disabled{% endif %}>
                                <span class="oe-nc-role-switch-item__icon-wrap oe-nc-role-switch-item__icon-wrap--{{ role.accent }}" aria-hidden="true">
                                    <i class="fa {{ role.icon }}"></i>
                                </span>
                                <span class="oe-nc-role-switch-item__body">
                                    <span class="oe-nc-role-switch-item__label">{{ role.label }}</span>
                                    <span class="oe-nc-role-switch-item__hint">{{ role.desk_label }}</span>
                                </span>
                                {% if role.is_active %}
                                    <i class="fa fa-check oe-nc-role-switch-item__check" aria-hidden="true"></i>
                                {% endif %}
                            </button>
                        {% endfor %}
                        <div class="oe-nc-role-switch__error alert alert-danger d-none m-2 py-2 small"
                             id="oe-nc-role-switch-error"
                             role="alert"></div>
                        <div class="dropdown-divider"></div>
                    {% endif %}
                    <a class="dropdown-item" href="{{ shell.profile_url|attr }}" target="_top">
                        <i class="fa fa-user mr-2 text-muted" aria-hidden="true"></i>
                        {{ 'My profile'|xlt }}
                    </a>
                    <a class="dropdown-item text-danger" href="{{ shell.logout_url|attr }}" target="_top">
                        <i class="fa fa-sign-out mr-2" aria-hidden="true"></i>
                        {{ 'Logout'|xlt }}
                    </a>
                </div>
            </div>

            <button type="button"
                    class="oe-nc-sidebar__collapse d-none d-lg-flex"
                    id="oe-nc-sidebar-collapse"
                    aria-expanded="true"
                    aria-controls="oe-nc-sidebar"
                    aria-label="{{ 'Collapse sidebar'|xlt }}">
                <span class="oe-nc-sidebar__collapse-icon" aria-hidden="true">
                    <i class="fa fa-angle-double-left"></i>
                </span>
                <span class="oe-nc-sidebar__expand-only">{{ 'Collapse'|xlt }}</span>
            </button>
        </div>
    </aside>
    {% endif %}

    <div class="oe-nc-shell-main">
        {% if not shell_minimal|default(false) %}
        <header class="oe-nc-mobile-bar d-lg-none">
            <button type="button"
                    class="btn btn-outline-secondary btn-sm oe-nc-mobile-bar__menu"
                    id="oe-nc-sidebar-open"
                    aria-expanded="false"
                    aria-controls="oe-nc-sidebar"
                    aria-label="{{ 'Open menu'|xlt }}">
                <i class="fa fa-bars" aria-hidden="true"></i>
            </button>
            <span class="oe-nc-mobile-bar__title">{{ page_title|xlt }}</span>
        </header>
        {% endif %}

        <main class="oe-nc-main" id="oe-nc-main">
            {% if desk_facility_fallback|default(false) %}
            <div class="alert alert-warning py-2 mx-3 mt-2 mb-0 small" role="status">
                {{ 'Your session facility is not available — showing the default clinic desk.'|xlt }}
            </div>
            {% endif %}
            {% block page_heading %}
            <header class="oe-nc-page-heading">
                <div class="oe-nc-page-heading__main">
                    <h1 class="oe-nc-page-heading__title">{{ page_title|xlt }}</h1>
                    {% block page_subtitle %}{% endblock %}
                </div>
                <div class="oe-nc-page-heading__actions">
                    {% block page_heading_actions %}{% endblock %}
                </div>
            </header>
            {% endblock %}
            <div class="oe-nc-content">
                {% block content %}{% endblock %}
            </div>
        </main>
    </div>
</div>

{% if shell.role.available|length > 1 %}
<div class="modal fade" id="oe-nc-role-confirm-modal" tabindex="-1" role="dialog" aria-labelledby="oe-nc-role-confirm-title" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title h6" id="oe-nc-role-confirm-title">{{ 'Switch role'|xlt }}</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="{{ 'Close'|xlt }}">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body py-2">
                <p class="mb-1 font-weight-bold" id="oe-nc-role-confirm-message"></p>
                <p class="text-muted small mb-0" id="oe-nc-role-confirm-desk"></p>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-dismiss="modal">{{ 'Cancel'|xlt }}</button>
                <button type="button" class="btn btn-sm btn-primary" id="oe-nc-role-confirm-btn">{{ 'Switch role'|xlt }}</button>
            </div>
        </div>
    </div>
</div>
{% endif %}

<script src="{{ assets_url }}/js/ui-components.js?v={{ asset_version }}"></script>
<script src="{{ assets_url }}/js/shell.js?v={{ asset_version }}"></script>
{% block scripts %}{% endblock %}
</body>
</html>
