<!DOCTYPE html>
<html lang="{{ lang_code|default('en') }}">
<head>
    <meta charset="UTF-8">
    <title>{{ page_title|xlt }}</title>
    {{ header_html|raw }}
    <link rel="stylesheet" href="{{ assets_url }}/css/tokens.css?v={{ asset_version }}">
    <link rel="stylesheet" href="{{ assets_url }}/css/shell.css?v={{ asset_version }}">
    <link rel="stylesheet" href="{{ assets_url }}/css/components.css?v={{ asset_version }}">
    <link rel="stylesheet" href="{{ assets_url }}/css/new-clinic.css?v={{ asset_version }}">
</head>
<body class="body_top">
<div id="nc-t1"
     class="nc-t1{% if shell_minimal|default(false) %} nc-t1-shell-minimal{% endif %}{% if shell_embed|default(false) %} nc-t1-embed{% endif %}{% if shell_desk_focus|default(false) %} nc-t1-desk-focus{% endif %}"
     data-role-accent="{{ shell.role.accent }}"
     data-ajax-url="{{ ajax_url }}"
     data-csrf-token="{{ csrf_token }}"
     data-facility-id="{{ desk_facility_id }}"
     data-queue-poll-ms="{{ queue_poll_ms|default(30000) }}"
     data-lang-code="{{ lang_code|default('en') }}"
     data-i18n-url="{{ i18n_url|default('')|attr }}">

    {# Stamp saved sidebar preferences BEFORE the sidebar parses/paints.
       shell.js (end of body) also applies these, but by then the light
       expanded rail has already painted — a visible flash of the wrong
       theme on every load for users with dark/collapsed saved, and a
       stuck-wrong sidebar if the script is delayed. Keys/classes must
       stay in sync with shell.js. #}
    <script>
        (function () {
            try {
                var cls = [];
                if (window.localStorage.getItem('nc-sidebar-dark') === '1') {
                    cls.push('nc-sidebar-dark');
                }
                if (
                    window.localStorage.getItem('nc-sidebar-collapsed') === '1'
                    || window.localStorage.getItem('oe-nc-sidebar-collapsed') === '1'
                ) {
                    cls.push('nc-t1-sidebar-collapsed');
                }
                if (cls.length) {
                    var root = document.getElementById('nc-t1');
                    root.className += ' ' + cls.join(' ');
                }
            } catch (e) { /* storage blocked — default light/expanded */ }
        })();
    </script>

    {% if not shell_minimal|default(false) %}
    <div class="nc-sidebar-backdrop" id="nc-sidebar-backdrop" hidden aria-hidden="true"></div>

    <aside class="nc-sidebar" id="nc-sidebar" aria-label="{{ 'Clinic navigation'|xlt }}">
        <div class="nc-sidebar-brand">
            <div class="nc-brand">
                {% if shell.brand.logo_url %}
                    <img src="{{ shell.brand.logo_url|attr }}" alt="" class="nc-brand-logo">
                {% else %}
                    <span class="nc-brand-initials" aria-hidden="true">{{ shell.brand.initials }}</span>
                {% endif %}
                <div class="nc-brand-text nc-sidebar-expand-only">
                    <p class="nc-brand-name nc-mb-0">{{ shell.brand.clinic_name|text }}</p>
                    {% if shell.brand.show_facility %}
                        <div class="nc-brand-facility">{{ shell.brand.facility_name|text }}</div>
                    {% endif %}
                </div>
            </div>
            <button type="button"
                    class="nc-btn nc-btn-sm nc-btn-link nc-sidebar-close nc-hidden-lg"
                    id="nc-sidebar-close"
                    aria-label="{{ 'Close menu'|xlt }}">
                <i class="fa fa-times" aria-hidden="true"></i>
            </button>
        </div>

        <div class="nc-brand-date nc-sidebar-expand-only nc-px-3 nc-pb-2" id="nc-today-label">{{ shell.today_label|text }}</div>

        <nav class="nc-sidebar-nav" aria-label="{{ 'Module pages'|xlt }}">
            {% for group in shell.nav_groups %}
                <div class="nc-sidebar-group" data-nav-group="{{ group.key }}">
                    <div class="nc-sidebar-group-label nc-sidebar-expand-only" id="nc-nav-group-{{ group.key }}">
                        {{ group.label }}
                    </div>
                    <ul class="nc-sidebar-list" role="list" aria-labelledby="nc-nav-group-{{ group.key }}">
                        {% for item in group.items %}
                            <li role="listitem">
                                <a href="{{ item.url|attr }}"
                                   class="nc-sidebar-link{% if item.active %} is-active{% endif %}"
                                   target="_top"
                                   data-nav-id="{{ item.id }}"
                                   {% if item.accent %}data-desk-accent="{{ item.accent }}"{% endif %}
                                   {% if item.badge_key %}data-badge-key="{{ item.badge_key }}"{% endif %}
                                   {% if item.active %}aria-current="page"{% endif %}
                                   title="{{ item.label }}">
                                    <span class="nc-sidebar-link-icon" aria-hidden="true">
                                        <i class="fa {{ item.icon }}"></i>
                                    </span>
                                    <span class="nc-sidebar-link-label nc-sidebar-expand-only">{{ item.label }}</span>
                                    {% if item.badge_key %}
                                        <span class="nc-sidebar-badge nc-sidebar-expand-only{% if item.badge_count == 0 %} is-zero{% endif %}"
                                              data-badge-count>{{ item.badge_count }}</span>
                                    {% endif %}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% endfor %}
        </nav>

        <div class="nc-sidebar-footer">
            <details class="nc-queue-kpi nc-sidebar-expand-only"
                      id="nc-queue-stats"
                      aria-label="{{ 'Today\'s queue counts'|xlt }}">
                <summary class="nc-queue-kpi-summary">
                    <span class="nc-queue-kpi-summary-label">{{ 'Queue'|xlt }}</span>
                    <span class="nc-queue-kpi-summary-active">
                        <span data-queue-active-total>{{ shell.queue_active_total }}</span>
                        {{ 'active'|xlt }}
                    </span>
                </summary>
                <div class="nc-queue-kpi-chips" aria-live="polite">
                    {% for stat in shell.queue_stats %}
                        <span class="nc-queue-kpi-chip{% if stat.key == 'done' %} nc-queue-kpi-chip-muted{% endif %}"
                              data-stat-key="{{ stat.key }}"
                              title="{{ stat.label }}">
                            <span class="nc-queue-kpi-chip-count" data-stat-count>{{ stat.count }}</span>
                            <span class="nc-queue-kpi-chip-label">{{ stat.short_label }}</span>
                        </span>
                    {% endfor %}
                </div>
            </details>

            <div class="nc-queue-kpi-mini nc-sidebar-collapse-only"
                 id="nc-queue-stats-mini"
                 aria-live="polite"
                 title="{{ 'Patients still in workflow'|xlt }}">
                <span class="nc-queue-kpi-mini-label">{{ 'Active'|xlt }}</span>
                <span class="nc-queue-kpi-mini-count" data-queue-active-total>{{ shell.queue_active_total }}</span>
            </div>

            <div class="nc-dropdown nc-sidebar-role nc-profile-card">
                <button type="button"
                        class="nc-profile-card-trigger nc-dropdown-toggle nc-w-full"
                        id="nc-role-pill"
                        data-nc-dropdown-toggle
                        aria-haspopup="true"
                        aria-expanded="false"
                        aria-label="{{ 'Active role menu'|xlt }}">
                    <span class="nc-profile-card-avatar-wrap" aria-hidden="true">
                        <span class="nc-profile-card-avatar">{{ shell.user.initials }}</span>
                    </span>
                    <span class="nc-profile-card-body nc-sidebar-expand-only">
                        <span class="nc-profile-card-name">
                            {{ shell.user.first_name|text }}{% if shell.user.last_name %} {{ shell.user.last_name|text }}{% endif %}
                        </span>
                        <span class="nc-profile-card-role">{{ shell.role.desk_label }}</span>
                    </span>
                    <span class="nc-profile-card-caret nc-sidebar-expand-only" aria-hidden="true">
                        <i class="fa fa-chevron-up"></i>
                    </span>
                </button>
                <div class="nc-dropdown-menu nc-role-menu nc-profile-card-menu" aria-labelledby="nc-role-pill">
                    <div class="nc-profile-card-menu-header">
                        <span class="nc-profile-card-menu-name">
                            {{ shell.user.first_name|text }}{% if shell.user.last_name %} {{ shell.user.last_name|text }}{% endif %}
                        </span>
                        <span class="nc-profile-card-menu-role">{{ shell.role.desk_label }}</span>
                    </div>
                    {% if shell.role.available|length > 1 %}
                        <div class="nc-dropdown-header nc-role-switch-heading">{{ 'Switch role'|xlt }}</div>
                        <p class="nc-role-switch-hint">{{ 'Shared device — pick who you are at this station.'|xlt }}</p>
                        {% for role in shell.role.available %}
                            <button type="button"
                                    class="nc-dropdown-item nc-role-switch-item{% if role.is_active %} is-active{% endif %}"
                                    data-role-aco="{{ role.aco }}"
                                    {% if role.is_active %}aria-current="true" disabled{% endif %}>
                                <span class="nc-role-switch-item-icon-wrap nc-role-switch-item-icon-wrap--{{ role.accent }}" aria-hidden="true">
                                    <i class="fa {{ role.icon }}"></i>
                                </span>
                                <span class="nc-role-switch-item-body">
                                    <span class="nc-role-switch-item-label">{{ role.desk_label }}</span>
                                    <span class="nc-role-switch-item-hint">{{ role.label }}</span>
                                </span>
                                {% if role.is_active %}
                                    <i class="fa fa-check nc-role-switch-item-check" aria-hidden="true"></i>
                                {% endif %}
                            </button>
                        {% endfor %}
                        <div class="nc-role-switch-error nc-callout nc-callout-error nc-hidden nc-m-2 nc-py-2 nc-text-sm"
                             id="nc-role-switch-error"
                             role="alert"></div>
                        <div class="nc-dropdown-divider"></div>
                    {% endif %}
                    <a class="nc-dropdown-item" href="{{ shell.profile_url|attr }}" target="_top">
                        <i class="fa fa-user nc-mr-2 nc-text-muted" aria-hidden="true"></i>
                        {{ 'My profile'|xlt }}
                    </a>
                    <a class="nc-dropdown-item nc-text-danger" href="{{ shell.logout_url|attr }}" target="_top">
                        <i class="fa fa-sign-out nc-mr-2" aria-hidden="true"></i>
                        {{ 'Logout'|xlt }}
                    </a>
                </div>
            </div>

            <button type="button"
                    class="nc-sidebar-theme-toggle"
                    id="nc-sidebar-theme-toggle"
                    aria-pressed="false"
                    aria-label="{{ 'Switch sidebar to dark appearance'|xlt }}">
                <span class="nc-sidebar-theme-toggle-icon" aria-hidden="true">
                    <i class="fa fa-moon-o"></i>
                </span>
                <span class="nc-sidebar-expand-only">{{ 'Dark sidebar'|xlt }}</span>
            </button>

            <button type="button"
                    class="nc-sidebar-collapse nc-hidden nc-flex-lg"
                    id="nc-sidebar-collapse"
                    aria-expanded="true"
                    aria-controls="nc-sidebar"
                    aria-label="{{ 'Collapse sidebar'|xlt }}">
                <span class="nc-sidebar-collapse-icon" aria-hidden="true">
                    <i class="fa fa-angle-double-left"></i>
                </span>
                <span class="nc-sidebar-expand-only">{{ 'Collapse'|xlt }}</span>
            </button>
        </div>
    </aside>
    {% endif %}

    <div class="nc-shell-main">
        {% if not shell_minimal|default(false) %}
        <header class="nc-mobile-bar nc-hidden-lg">
            <button type="button"
                    class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary nc-mobile-bar-menu"
                    id="nc-sidebar-open"
                    aria-expanded="false"
                    aria-controls="nc-sidebar"
                    aria-label="{{ 'Open menu'|xlt }}">
                <i class="fa fa-bars" aria-hidden="true"></i>
            </button>
            <span class="nc-mobile-bar-title">{{ page_title|xlt }}</span>
        </header>
        {% endif %}

        <main class="nc-main" id="nc-main">
            {% if desk_facility_fallback|default(false) %}
            <div class="nc-callout nc-callout-warn nc-py-2 nc-mx-3 nc-mt-2 nc-mb-0 nc-text-sm" role="status">
                {{ 'Your session facility is not available — showing the default clinic desk.'|xlt }}
            </div>
            {% endif %}
            {% block page_heading %}
            <header class="nc-page-heading">
                <div class="nc-page-heading-main">
                    <h1 class="nc-page-heading-title">{{ page_title|xlt }}</h1>
                    {% block page_subtitle %}{% endblock %}
                </div>
                <div class="nc-page-heading-actions">
                    {% block page_heading_actions %}{% endblock %}
                </div>
            </header>
            {% endblock %}
            <div class="nc-content">
                {% block content %}{% endblock %}
            </div>
        </main>
    </div>
</div>

{% if shell.role.available|length > 1 %}
<div class="nc-modal" id="nc-role-confirm-modal" tabindex="-1" role="dialog" aria-labelledby="nc-role-confirm-title" aria-hidden="true" hidden>
    <div class="nc-modal-dialog nc-modal-dialog-centered" role="document">
        <div class="nc-modal-content">
            <div class="nc-modal-header nc-py-2">
                <h5 class="nc-modal-title" id="nc-role-confirm-title">{{ 'Switch role'|xlt }}</h5>
                <button type="button" class="nc-modal-close" data-nc-modal-dismiss aria-label="{{ 'Close'|xlt }}">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="nc-modal-body nc-py-2">
                <p class="nc-mb-1 nc-font-bold" id="nc-role-confirm-message"></p>
                <p class="nc-text-muted nc-text-sm nc-mb-0" id="nc-role-confirm-desk"></p>
            </div>
            <div class="nc-modal-footer nc-py-2">
                <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary" data-nc-modal-dismiss>{{ 'Cancel'|xlt }}</button>
                <button type="button" class="nc-btn nc-btn-sm nc-btn-primary" id="nc-role-confirm-btn">{{ 'Switch role'|xlt }}</button>
            </div>
        </div>
    </div>
</div>
{% endif %}

<script src="{{ assets_url }}/js/ui-components.js?v={{ asset_version }}"></script>
<script src="{{ assets_url }}/js/shell.js?v={{ asset_version }}"></script>
{% block scripts %}{% endblock %}
</body>
</html>
