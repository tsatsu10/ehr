{# patient-context-banner — Tier 1–3 (static shell; JS fills dynamic fields) #}
<div class="nc-patient-banner nc-patient-context-banner"
     id="nc-patient-context-banner"
     data-tier="{{ tier|default(1) }}"
     data-host="{{ host|default('front-desk') }}">
    <div class="nc-patient-banner-header">
        <div class="nc-patient-banner-avatar" id="nc-banner-avatar" aria-hidden="true">—</div>
        <div class="nc-patient-banner-identity">
            <h3 class="nc-patient-banner-name" id="nc-banner-name">—</h3>
            <div class="nc-patient-banner-meta" id="nc-banner-meta"></div>
        </div>
        <div class="nc-patient-banner-aside text-right">
            <div id="nc-banner-completion-wrap">
                <span class="nc-status-pill nc-status-pill-neutral" id="nc-banner-completion">
                    <span class="nc-status-pill-dot" aria-hidden="true"></span>
                    <span>—</span>
                </span>
            </div>
        </div>
    </div>

    <div class="nc-patient-banner-section" id="nc-banner-safety" aria-label="{{ 'Safety'|xlt }}"></div>
    <div class="nc-patient-banner-section" id="nc-banner-visit"></div>

    {% if show_start_visit|default(false) %}
    <div class="nc-border-t nc-pt-3 nc-mt-2" id="nc-start-visit-panel">
        <h6 class="nc-font-bold">{{ 'Start visit'|xlt }}</h6>
        <div class="nc-form-group">
            <label for="nc-visit-type">{{ 'Visit type'|xlt }}</label>
            <select class="nc-select" id="nc-visit-type"></select>
        </div>
        <div class="nc-form-group">
            <label for="nc-chief-complaint">{{ 'Chief complaint'|xlt }}</label>
            <input type="text" class="nc-input" id="nc-chief-complaint" maxlength="500" placeholder="{{ 'Optional'|xlt }}">
        </div>
        <div class="nc-form-check nc-mb-3">
            <input type="checkbox" class="nc-form-check-input" id="nc-is-urgent">
            <label class="nc-form-check-label" for="nc-is-urgent">{{ 'Urgent'|xlt }}</label>
        </div>
        {% include 'partials/ui/btn-primary-lg.html.twig' with {
            id: 'nc-start-visit-btn',
            label: 'Start visit',
            icon: 'fa-play',
            disabled: true
        } %}
        <div class="nc-callout nc-callout-success nc-mt-2 nc-hidden" id="nc-start-visit-success" role="alert"></div>
        <div class="nc-callout nc-callout-error nc-mt-2 nc-hidden" id="nc-start-visit-error" role="alert"></div>
    </div>
    {% endif %}
</div>
