<div class="nc-widget-card nc-patient-search"
     id="nc-patient-search"
     data-host="{{ host|default('front-desk') }}"
     data-primary-action="{{ primary_action|default('start_visit') }}"
     data-ajax-url="{{ ajax_url }}"
     data-csrf-token="{{ csrf_token }}">
    <div class="nc-widget-card-header">
        <h2 class="nc-widget-card-title">{{ 'Patient search'|xlt }}</h2>
        {% if show_add_new|default(true) %}
        <button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-success" id="nc-add-patient">
            <i class="fa fa-user-plus nc-mr-1" aria-hidden="true"></i>
            {{ add_patient_label|default('Register patient')|xlt }}
        </button>
        {% endif %}
    </div>
    <div class="nc-widget-card-body nc-widget-card-body-flush">
        <div class="nc-p-3 nc-border-b">
            {% include 'partials/ui/search-input.html.twig' with {
                id: 'nc-search-input',
                placeholder: 'Search by name, phone, NHIS, National ID, MRN',
                autofocus: autofocus|default(false),
                hint_id: 'nc-search-hint',
                hint_text: 'Type at least 2 characters · press / to focus'
            } %}
            <div class="nc-callout nc-callout-error nc-mt-2 nc-hidden" id="nc-search-error" role="alert"></div>
        </div>
        <div id="nc-search-results"
             class="nc-list-group nc-list-group-flush nc-search-results nc-desk-split-search"
             role="listbox"
             aria-label="{{ 'Search results'|xlt }}">
            <div class="nc-list-group-item nc-text-muted" id="nc-search-empty" role="option">
                {{ 'Results appear here'|xlt }}
            </div>
        </div>
    </div>
</div>
