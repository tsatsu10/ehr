{% extends 'base.html.twig' %}

{% block page_subtitle %}
<div class="nc-page-heading-subtitle" id="nc-triage-date"></div>
{% endblock %}

{% block page_heading_actions %}
<button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-secondary" id="nc-triage-find-patient">
    {{ '+ Find patient'|xlt }}
</button>
<button type="button" class="nc-btn nc-btn-sm nc-btn-outline nc-btn-outline-primary" id="nc-triage-refresh">
    {{ 'Refresh'|xlt }}
</button>
<span class="nc-text-muted nc-text-sm" id="nc-triage-updated"></span>
{% endblock %}

{% block content %}
{% if enable_react_triage_desk|default(true) %}
<div
    data-island="triage-desk"
    data-props="{{ {
        ajaxUrl:             ajax_url,
        csrfToken:           csrf_token,
        facilityId:          desk_facility_id|default(0)|number_format(0, '', ''),
        visitBoardUrl:       module_url ~ '/visit-board.php',
        vitalsRules:         vitals_form_rules,
        canCancel:           can_cancel_visit ? true : false,
        sharedDeviceWarning: enable_shared_device_session_warning ? true : false,
        pollMs:                  queue_poll_ms|default(30000)
    }|json_encode|e('html_attr') }}"
></div>
{% else %}
{% include 'partials/react-island-disabled.html.twig' with { desk_label: 'Triage Desk' } %}
{% endif %}
{% endblock %}

{% block scripts %}
{% if enable_react_triage_desk|default(true) %}
{% include 'partials/island-assets.html.twig' %}
{% endif %}
{% endblock %}
